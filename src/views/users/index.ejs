<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800">User Management</h1>
    <p class="text-gray-500 text-sm mt-1">Create and manage admin accounts</p>
  </div>
  <a href="/users/create" class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-lg text-sm transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Add User
  </a>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left px-5 py-3 font-semibold text-gray-600">Name</th>
        <th class="text-left px-5 py-3 font-semibold text-gray-600">Email</th>
        <th class="text-center px-5 py-3 font-semibold text-gray-600">Role</th>
        <th class="text-center px-5 py-3 font-semibold text-gray-600">Status</th>
        <th class="text-right px-5 py-3 font-semibold text-gray-600">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% users.forEach(u => { %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-5 py-3 font-medium text-gray-800"><%= u.name %></td>
          <td class="px-5 py-3 text-gray-600"><%= u.email %></td>
          <td class="px-5 py-3 text-center">
            <% const roleColors = {superadmin:'bg-red-100 text-red-700',my_admin:'bg-indigo-100 text-indigo-700',malaysian_admin:'bg-teal-100 text-teal-700'}; %>
            <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= roleColors[u.role] %>"><%= u.role.replace('_',' ') %></span>
          </td>
          <td class="px-5 py-3 text-center">
            <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= u.is_active ? 'bg-emerald-100 text-emerald-700' : 'bg-gray-100 text-gray-500' %>">
              <%= u.is_active ? 'Active' : 'Disabled' %>
            </span>
          </td>
          <td class="px-5 py-3 text-right space-x-2">
            <% if (u.id !== user.id) { %>
              <a href="/auth/impersonate/<%= u.id %>" class="text-amber-600 hover:text-amber-500 font-medium text-xs" title="View as this user">Impersonate</a>
            <% } %>
            <a href="/users/<%= u.id %>/edit" class="text-indigo-600 hover:text-indigo-500 font-medium text-xs">Edit</a>
            <% if (u.id !== user.id) { %>
              <form method="POST" action="/users/<%= u.id %>/delete" class="inline" onsubmit="return confirm('Delete this user?')">
                <button type="submit" class="text-red-500 hover:text-red-600 font-medium text-xs">Delete</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
