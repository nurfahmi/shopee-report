<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
  <div>
    <h1 class="text-xl sm:text-2xl font-bold text-gray-800">Clients</h1>
    <p class="text-gray-500 text-sm mt-1">Manage your development clients</p>
  </div>
  <a href="/invoices/clients/create" class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-lg text-sm transition-colors whitespace-nowrap">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Add Client
  </a>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <div class="overflow-x-auto">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left px-5 py-3 font-semibold text-gray-600">Name</th>
        <th class="text-left px-5 py-3 font-semibold text-gray-600">Company</th>
        <th class="text-left px-5 py-3 font-semibold text-gray-600">Email</th>
        <th class="text-left px-5 py-3 font-semibold text-gray-600">Phone</th>
        <th class="text-right px-5 py-3 font-semibold text-gray-600">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if (clients.length === 0) { %>
        <tr><td colspan="5" class="px-5 py-8 text-center text-gray-400">No clients yet.</td></tr>
      <% } %>
      <% clients.forEach(c => { %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-5 py-3 font-medium text-gray-800"><%= c.name %></td>
          <td class="px-5 py-3 text-gray-600"><%= c.company || '-' %></td>
          <td class="px-5 py-3 text-gray-600"><%= c.email || '-' %></td>
          <td class="px-5 py-3 text-gray-600"><%= c.phone || '-' %></td>
          <td class="px-5 py-3 text-right space-x-2">
            <a href="/invoices/clients/<%= c.id %>/edit" class="text-indigo-600 hover:text-indigo-500 font-medium text-xs">Edit</a>
            <form method="POST" action="/invoices/clients/<%= c.id %>/delete" class="inline" onsubmit="return confirm('Delete?')">
              <button type="submit" class="text-red-500 hover:text-red-600 font-medium text-xs">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  </div>
</div>
