<div class="max-w-xl">
  <h1 class="text-2xl font-bold text-gray-800 mb-6"><%= editing ? 'Edit' : 'New' %> Project</h1>
  <form method="POST" action="<%= editing ? `/invoices/projects/${data.id}/edit` : '/invoices/projects/create' %>"
    enctype="multipart/form-data" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-5">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Client</label>
      <select name="client_id" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm bg-white">
        <option value="">Select client...</option>
        <% clients.forEach(c => { %>
          <option value="<%= c.id %>" <%= (data.client_id == c.id) ? 'selected' : '' %>><%= c.name %> <% if(c.company) { %>(<%= c.company %>)<% } %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Project Name</label>
      <input type="text" name="project_name" value="<%= data.project_name || '' %>" required
        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
      <textarea name="description" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm"><%= data.description || '' %></textarea>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Scope MD File (optional)</label>
      <input type="file" name="scope_md" accept=".md,.txt"
        class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm file:mr-3 file:py-1 file:px-3 file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700">
    </div>
    <% if (editing) { %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
      <select name="status" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm bg-white">
        <option value="active" <%= data.status === 'active' ? 'selected' : '' %>>Active</option>
        <option value="completed" <%= data.status === 'completed' ? 'selected' : '' %>>Completed</option>
        <option value="cancelled" <%= data.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
      </select>
    </div>
    <% } %>
    <div class="flex gap-3 pt-2">
      <button type="submit" class="px-5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-lg text-sm transition-colors"><%= editing ? 'Update' : 'Create' %> Project</button>
      <a href="/invoices/projects" class="px-5 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-lg text-sm transition-colors">Cancel</a>
    </div>
  </form>
</div>
