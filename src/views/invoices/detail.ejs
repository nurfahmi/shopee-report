<div class="max-w-4xl">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
      <a href="/invoices" class="text-gray-400 hover:text-gray-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </a>
      <div>
        <h1 class="text-2xl font-bold text-gray-800"><%= invoice.invoice_number %></h1>
        <p class="text-gray-500 text-sm"><%= invoice.project_name %> · <%= invoice.client_name %></p>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <% const ic = {draft:'bg-gray-100 text-gray-600',sent:'bg-blue-100 text-blue-700',partial:'bg-amber-100 text-amber-700',paid:'bg-emerald-100 text-emerald-700'}; %>
      <span class="px-3 py-1 rounded-full text-xs font-semibold <%= ic[invoice.status] %>"><%= invoice.status.toUpperCase() %></span>
      <a href="/invoices/<%= invoice.id %>/pdf" target="_blank" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-800 hover:bg-gray-700 text-white font-medium rounded-lg text-xs transition-colors">View PDF</a>
      <a href="/invoices/<%= invoice.id %>/pdf?download=1" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-lg text-xs transition-colors">Download</a>
    </div>
  </div>

  <!-- Invoice Info Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500">Issued By</p>
      <p class="text-sm font-semibold text-gray-800 mt-1"><%= invoice.business_name %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500">Issue Date</p>
      <p class="text-sm font-semibold text-gray-800 mt-1"><%= invoice.issue_date ? new Date(invoice.issue_date).toLocaleDateString('en-GB') : '-' %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500">Total</p>
      <p class="text-xl font-bold text-gray-800 mt-1"><%= invoice.currency || 'MYR' %> <%= parseFloat(invoice.total).toLocaleString('en-MY',{minimumFractionDigits:2}) %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-4">
      <p class="text-xs font-medium text-gray-500">Balance Due</p>
      <p class="text-xl font-bold mt-1 <%= parseFloat(invoice.balance_due) > 0 ? 'text-red-500' : 'text-emerald-600' %>">
        <%= invoice.currency || 'MYR' %> <%= parseFloat(invoice.balance_due).toLocaleString('en-MY',{minimumFractionDigits:2}) %>
      </p>
    </div>
  </div>

  <!-- Line Items -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-6">
    <div class="p-4 bg-gray-50 border-b border-gray-200"><p class="text-sm font-semibold text-gray-700">Line Items</p></div>
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-5 py-3 font-semibold text-gray-600">Phase</th>
          <th class="text-left px-5 py-3 font-semibold text-gray-600">Description</th>
          <th class="text-right px-5 py-3 font-semibold text-gray-600">Qty</th>
          <th class="text-right px-5 py-3 font-semibold text-gray-600">Price</th>
          <th class="text-right px-5 py-3 font-semibold text-gray-600">Amount</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% items.forEach(it => { %>
          <tr>
            <td class="px-5 py-3 text-gray-500"><%= it.phase_label || '' %></td>
            <td class="px-5 py-3 text-gray-800"><%= it.description %></td>
            <td class="px-5 py-3 text-right text-gray-600"><%= it.quantity %></td>
            <td class="px-5 py-3 text-right text-gray-600"><%= parseFloat(it.unit_price).toLocaleString('en-MY',{minimumFractionDigits:2}) %></td>
            <td class="px-5 py-3 text-right font-medium text-gray-800"><%= parseFloat(it.amount).toLocaleString('en-MY',{minimumFractionDigits:2}) %></td>
          </tr>
        <% }) %>
      </tbody>
      <tfoot class="bg-gray-50">
        <tr class="border-t border-gray-200">
          <td colspan="4" class="px-5 py-2 text-right text-sm text-gray-600">Subtotal</td>
          <td class="px-5 py-2 text-right font-medium text-gray-800"><%= parseFloat(invoice.subtotal).toLocaleString('en-MY',{minimumFractionDigits:2}) %></td>
        </tr>
        <% if (parseFloat(invoice.tax_percent) > 0) { %>
        <tr>
          <td colspan="4" class="px-5 py-2 text-right text-sm text-gray-600">Tax (<%= invoice.tax_percent %>%)</td>
          <td class="px-5 py-2 text-right font-medium text-gray-800"><%= parseFloat(invoice.tax_amount).toLocaleString('en-MY',{minimumFractionDigits:2}) %></td>
        </tr>
        <% } %>
        <tr class="border-t border-gray-300">
          <td colspan="4" class="px-5 py-3 text-right text-sm font-bold text-gray-800">Total</td>
          <td class="px-5 py-3 text-right font-bold text-gray-800 text-lg"><%= parseFloat(invoice.total).toLocaleString('en-MY',{minimumFractionDigits:2}) %></td>
        </tr>
      </tfoot>
    </table>
  </div>

  <!-- Milestones -->
  <% if (invoice.payment_type === 'milestone' && milestones.length > 0) { %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-6">
    <div class="p-4 bg-gray-50 border-b border-gray-200"><p class="text-sm font-semibold text-gray-700">Payment Milestones</p></div>
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-5 py-3 font-semibold text-gray-600">Milestone</th>
          <th class="text-right px-5 py-3 font-semibold text-gray-600">%</th>
          <th class="text-right px-5 py-3 font-semibold text-gray-600">Amount</th>
          <th class="text-left px-5 py-3 font-semibold text-gray-600">Due</th>
          <th class="text-center px-5 py-3 font-semibold text-gray-600">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% milestones.forEach(m => { %>
          <tr>
            <td class="px-5 py-3 font-medium text-gray-800"><%= m.label %></td>
            <td class="px-5 py-3 text-right text-gray-600"><%= m.percent %>%</td>
            <td class="px-5 py-3 text-right font-medium text-gray-800"><%= parseFloat(m.amount).toLocaleString('en-MY',{minimumFractionDigits:2}) %></td>
            <td class="px-5 py-3 text-gray-600"><%= m.due_date ? new Date(m.due_date).toLocaleDateString('en-GB') : '-' %></td>
            <td class="px-5 py-3 text-center">
              <% const mc = {pending:'bg-amber-100 text-amber-700',invoiced:'bg-blue-100 text-blue-700',paid:'bg-emerald-100 text-emerald-700'}; %>
              <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= mc[m.status] %>"><%= m.status %></span>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>

  <!-- Payments History -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-6">
    <div class="p-4 bg-gray-50 border-b border-gray-200"><p class="text-sm font-semibold text-gray-700">Payments Received</p></div>
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-5 py-3 font-semibold text-gray-600">Date</th>
          <th class="text-right px-5 py-3 font-semibold text-gray-600">Amount</th>
          <th class="text-left px-5 py-3 font-semibold text-gray-600">Method</th>
          <th class="text-left px-5 py-3 font-semibold text-gray-600">Reference</th>
          <th class="text-left px-5 py-3 font-semibold text-gray-600">Notes</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if (payments.length === 0) { %>
          <tr><td colspan="5" class="px-5 py-4 text-center text-gray-400">No payments recorded yet.</td></tr>
        <% } %>
        <% payments.forEach(p => { %>
          <tr>
            <td class="px-5 py-3 text-gray-600"><%= new Date(p.payment_date).toLocaleDateString('en-GB') %></td>
            <td class="px-5 py-3 text-right font-medium text-emerald-600">+ <%= parseFloat(p.amount).toLocaleString('en-MY',{minimumFractionDigits:2}) %></td>
            <td class="px-5 py-3 text-gray-600"><%= p.method || '-' %></td>
            <td class="px-5 py-3 text-gray-600"><%= p.reference || '-' %></td>
            <td class="px-5 py-3 text-gray-500 text-xs"><%= p.notes || '' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Actions -->
  <div class="flex flex-wrap gap-3">
    <% if (invoice.status === 'draft') { %>
      <form method="POST" action="/invoices/<%= invoice.id %>/mark-sent" class="inline">
        <button type="submit" class="px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white font-medium rounded-lg text-sm transition-colors">Mark as Sent</button>
      </form>
      <a href="/invoices/<%= invoice.id %>/edit" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-lg text-sm transition-colors">Edit</a>
    <% } %>

    <% if (['sent','partial'].includes(invoice.status)) { %>
      <!-- Record Payment Form -->
      <div class="w-full bg-white rounded-xl border border-gray-200 p-5 mt-2">
        <p class="text-sm font-semibold text-gray-700 mb-3">Record Payment</p>
        <form method="POST" action="/invoices/<%= invoice.id %>/payment" class="grid grid-cols-2 md:grid-cols-5 gap-3">
          <% if (invoice.payment_type === 'milestone' && milestones.filter(m => m.status !== 'paid').length > 0) { %>
            <select name="milestone_id" class="px-2 py-2 border border-gray-300 rounded text-sm bg-white">
              <option value="">General Payment</option>
              <% milestones.filter(m => m.status !== 'paid').forEach(m => { %>
                <option value="<%= m.id %>"><%= m.label %> (<%= parseFloat(m.amount).toFixed(2) %>)</option>
              <% }) %>
            </select>
          <% } %>
          <input type="number" name="amount" step="0.01" required placeholder="Amount" class="px-2 py-2 border border-gray-300 rounded text-sm">
          <input type="date" name="payment_date" required value="<%= new Date().toISOString().split('T')[0] %>" class="px-2 py-2 border border-gray-300 rounded text-sm">
          <input type="text" name="method" placeholder="Method (Bank/Cash)" class="px-2 py-2 border border-gray-300 rounded text-sm">
          <input type="text" name="reference" placeholder="Ref No." class="px-2 py-2 border border-gray-300 rounded text-sm">
          <button type="submit" class="px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white font-medium rounded text-sm transition-colors col-span-2 md:col-span-1">Record</button>
        </form>
      </div>
    <% } %>

    <% if (invoice.status === 'draft') { %>
      <form method="POST" action="/invoices/<%= invoice.id %>/delete" class="inline" onsubmit="return confirm('Delete this invoice?')">
        <button type="submit" class="px-4 py-2 bg-red-50 hover:bg-red-100 text-red-600 font-medium rounded-lg text-sm transition-colors border border-red-200">Delete</button>
      </form>
    <% } %>
  </div>
</div>
