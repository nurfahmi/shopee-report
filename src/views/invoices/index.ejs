<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Invoices</h1>
    <p class="text-gray-500 text-sm mt-1">Client invoices for development projects</p>
  </div>
  <a href="/invoices/create" class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-lg text-sm transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    New Invoice
  </a>
</div>

<div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="text-left px-5 py-3 font-semibold text-gray-600">Invoice</th>
        <th class="text-left px-5 py-3 font-semibold text-gray-600">Client</th>
        <th class="text-left px-5 py-3 font-semibold text-gray-600">Issued By</th>
        <th class="text-right px-5 py-3 font-semibold text-gray-600">Total</th>
        <th class="text-right px-5 py-3 font-semibold text-gray-600">Balance</th>
        <th class="text-center px-5 py-3 font-semibold text-gray-600">Status</th>
        <th class="text-right px-5 py-3 font-semibold text-gray-600">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% if (invoices.length === 0) { %>
        <tr><td colspan="7" class="px-5 py-8 text-center text-gray-400">No invoices yet.</td></tr>
      <% } %>
      <% invoices.forEach(inv => { %>
        <tr class="hover:bg-gray-50 transition-colors">
          <td class="px-5 py-3">
            <a href="/invoices/<%= inv.id %>" class="text-indigo-600 hover:underline font-medium"><%= inv.invoice_number %></a>
            <p class="text-xs text-gray-400"><%= inv.project_name %></p>
          </td>
          <td class="px-5 py-3 text-gray-600"><%= inv.client_name %></td>
          <td class="px-5 py-3 text-gray-500 text-xs"><%= inv.business_name %></td>
          <td class="px-5 py-3 text-right font-medium text-gray-800"><%= parseFloat(inv.total || 0).toLocaleString('en-MY',{minimumFractionDigits:2}) %></td>
          <td class="px-5 py-3 text-right font-medium <%= parseFloat(inv.balance_due) > 0 ? 'text-red-500' : 'text-emerald-600' %>">
            <%= parseFloat(inv.balance_due || 0).toLocaleString('en-MY',{minimumFractionDigits:2}) %>
          </td>
          <td class="px-5 py-3 text-center">
            <% const ic = {draft:'bg-gray-100 text-gray-600',sent:'bg-blue-100 text-blue-700',partial:'bg-amber-100 text-amber-700',paid:'bg-emerald-100 text-emerald-700'}; %>
            <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= ic[inv.status] %>"><%= inv.status %></span>
          </td>
          <td class="px-5 py-3 text-right">
            <a href="/invoices/<%= inv.id %>" class="text-indigo-600 hover:text-indigo-500 font-medium text-xs">View</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
