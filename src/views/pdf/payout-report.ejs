<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Payout Report — <%= period.period_number %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-white text-gray-900 p-8">
  <div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="flex justify-between items-start mb-8 pb-6 border-b-2 border-indigo-600">
      <div>
        <h1 class="text-2xl font-bold text-indigo-600">PAYOUT REPORT</h1>
        <p class="text-sm text-gray-500 mt-1"><%= period.period_number %></p>
      </div>
      <div class="text-right">
        <p class="font-bold text-lg">Indosofthouse</p>
        <p class="text-sm text-gray-500">Malaysia / Indonesia</p>
      </div>
    </div>

    <!-- Period Info -->
    <div class="grid grid-cols-3 gap-6 mb-8">
      <div>
        <p class="text-xs text-gray-500">Period</p>
        <p class="font-semibold"><%= period.period_label %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500">Payout Date</p>
        <p class="font-semibold"><%= period.payout_date ? new Date(period.payout_date).toLocaleDateString('en-GB') : '-' %></p>
      </div>
      <div>
        <p class="text-xs text-gray-500">Status</p>
        <p class="font-semibold capitalize"><%= period.status.replace(/_/g,' ') %></p>
      </div>
    </div>

    <!-- Entries Table -->
    <table class="w-full text-sm mb-8">
      <thead>
        <tr class="border-b-2 border-gray-300">
          <th class="text-left py-2 font-semibold">No</th>
          <th class="text-left py-2 font-semibold">Bank Account</th>
          <th class="text-right py-2 font-semibold">Payout Amount (MYR)</th>
          <th class="text-center py-2 font-semibold">Status</th>
          <th class="text-left py-2 font-semibold">Payment Time</th>
        </tr>
      </thead>
      <tbody>
        <% entries.forEach((e, i) => { %>
          <tr class="border-b border-gray-200">
            <td class="py-2"><%= i + 1 %></td>
            <td class="py-2 font-medium"><%= e.affiliate_name || e.extracted_name || 'Unknown' %></td>
            <td class="py-2 text-right font-medium"><%= parseFloat(e.payout_amount).toLocaleString('en-MY',{minimumFractionDigits:2}) %></td>
            <td class="py-2 text-center capitalize"><%= e.payment_status %></td>
            <td class="py-2"><%= e.payment_time ? new Date(e.payment_time).toLocaleString('en-GB') : '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <!-- Summary -->
    <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
      <div class="grid grid-cols-2 gap-3">
        <div class="text-sm text-gray-600">Total Gross Payout</div>
        <div class="text-right font-semibold">MYR <%= parseFloat(period.total_gross || 0).toLocaleString('en-MY',{minimumFractionDigits:2}) %></div>

        <div class="text-sm text-gray-600">Deduction (<%= period.deduction_percent || 0 %>%)</div>
        <div class="text-right font-semibold text-red-500">- MYR <%= parseFloat(period.deduction_amount || 0).toLocaleString('en-MY',{minimumFractionDigits:2}) %></div>

        <div class="border-t border-gray-300 col-span-2 my-2"></div>

        <div class="text-base font-bold text-gray-800">Net Transfer to ISH</div>
        <div class="text-right text-xl font-bold text-emerald-600">MYR <%= parseFloat(period.net_to_ish || 0).toLocaleString('en-MY',{minimumFractionDigits:2}) %></div>
      </div>
    </div>

    <p class="text-xs text-gray-400 mt-8 text-center">Generated by Shopee Report · <%= new Date().toLocaleDateString('en-GB') %></p>
  </div>
</body>
</html>
