<%
  const fmtIDR = n => (Math.floor(Math.max(0, parseFloat(n||0)) / 100) * 100).toLocaleString('id-ID');
  const today = new Date();
  const todayStr = today.toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' });
%>
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Slip Gaji — <%= staff.name %> · <%= periodLabel %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    @page { size: A4; margin: 18mm; }
  </style>
</head>
<body class="bg-white text-slate-900 p-6">
  <div class="max-w-3xl mx-auto">

    <!-- Kop -->
    <div class="flex items-start justify-between border-b-2 border-slate-900 pb-4 mb-6">
      <div>
        <h1 class="text-2xl font-bold tracking-tight">SLIP GAJI</h1>
        <p class="text-[12px] text-slate-500 mt-0.5">Nomor: SG/<%= studio.id %>/<%= staff.id %>/<%= period ? period.year : '----' %><%= period ? String(period.month).padStart(2,'0') : '--' %></p>
      </div>
      <div class="text-right">
        <p class="text-lg font-bold tracking-tight"><%= studio.name %></p>
        <% if (studio.bank_name) { %>
          <p class="text-[11px] text-slate-500"><%= studio.bank_name %></p>
        <% } %>
        <p class="text-[11px] text-slate-400 mt-0.5">Diterbitkan: <%= todayStr %></p>
      </div>
    </div>

    <!-- Info Karyawan & Periode -->
    <div class="grid grid-cols-2 gap-6 mb-6">
      <div>
        <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Karyawan</p>
        <p class="text-base font-bold text-slate-900"><%= staff.name %></p>
        <% if (staff.role_title) { %>
          <p class="text-[12px] text-slate-600"><%= staff.role_title %></p>
        <% } %>
        <p class="text-[11px] text-slate-400 mt-1">ID: <%= staff.id %></p>
      </div>
      <div class="text-right">
        <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Periode</p>
        <p class="text-base font-bold text-slate-900"><%= periodLabel %></p>
        <p class="text-[11px] text-slate-500 mt-0.5">
          Tipe Gaji:
          <span class="font-semibold"><%= salaryType === 'fixed' ? 'Bulanan Tetap' : 'Per Jam' %></span>
        </p>
        <% if (salaryType === 'hourly') { %>
          <p class="text-[11px] text-slate-500">Tarif: IDR <%= fmtIDR(hourlyRate) %> / jam</p>
        <% } else { %>
          <p class="text-[11px] text-slate-500">Gaji Pokok: IDR <%= fmtIDR(monthly) %> / bulan</p>
        <% } %>
      </div>
    </div>

    <!-- Rincian -->
    <div class="border border-slate-300 rounded-lg overflow-hidden mb-6">
      <table class="w-full text-[13px]">
        <thead class="bg-slate-100 text-slate-600 text-[10px] uppercase tracking-wider">
          <tr>
            <th class="text-left  px-4 py-2.5 font-semibold">Komponen</th>
            <th class="text-right px-4 py-2.5 font-semibold">Perhitungan</th>
            <th class="text-right px-4 py-2.5 font-semibold">Jumlah (IDR)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          <!-- Gaji Pokok -->
          <tr>
            <td class="px-4 py-2.5">
              <p class="font-semibold text-slate-900">Gaji Pokok</p>
              <p class="text-[11px] text-slate-500">
                <%= salaryType === 'fixed' ? 'Gaji bulanan tetap' : `${hours} jam × IDR ${fmtIDR(hourlyRate)}` %>
              </p>
            </td>
            <td class="px-4 py-2.5 text-right text-[11px] text-slate-500 tabular-nums">
              <%= salaryType === 'fixed' ? '1 × IDR ' + fmtIDR(monthly) : `${hours} × ${fmtIDR(hourlyRate)}` %>
            </td>
            <td class="px-4 py-2.5 text-right font-semibold tabular-nums">IDR <%= fmtIDR(base) %></td>
          </tr>

          <!-- Uang Makan -->
          <% if (cashback > 0) { %>
            <tr>
              <td class="px-4 py-2.5">
                <p class="font-semibold text-slate-900">Uang Makan</p>
                <p class="text-[11px] text-slate-500"><%= days %> hari × IDR <%= fmtIDR(cashback) %> / hari</p>
              </td>
              <td class="px-4 py-2.5 text-right text-[11px] text-slate-500 tabular-nums"><%= days %> × <%= fmtIDR(cashback) %></td>
              <td class="px-4 py-2.5 text-right font-semibold tabular-nums">IDR <%= fmtIDR(lunchTotal) %></td>
            </tr>
          <% } %>

          <!-- Tunjangan -->
          <% if (tunjangan > 0) { %>
            <tr>
              <td class="px-4 py-2.5">
                <p class="font-semibold text-slate-900">Tunjangan</p>
                <p class="text-[11px] text-slate-500">Tunjangan tetap bulanan</p>
              </td>
              <td class="px-4 py-2.5 text-right text-[11px] text-slate-500 tabular-nums">—</td>
              <td class="px-4 py-2.5 text-right font-semibold tabular-nums">IDR <%= fmtIDR(tunjangan) %></td>
            </tr>
          <% } %>
        </tbody>
        <tfoot class="bg-emerald-50 border-t-2 border-emerald-700">
          <tr>
            <td class="px-4 py-3 font-bold text-emerald-700 uppercase text-[11px] tracking-wider" colspan="2">Total Gaji Diterima</td>
            <td class="px-4 py-3 text-right text-lg font-bold text-emerald-700 tabular-nums">IDR <%= fmtIDR(total) %></td>
          </tr>
        </tfoot>
      </table>
    </div>

    <!-- Catatan -->
    <% if (payout && payout.notes) { %>
      <div class="mb-6">
        <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Catatan</p>
        <p class="text-[12px] text-slate-700 border-l-2 border-slate-300 pl-3"><%= payout.notes %></p>
      </div>
    <% } %>

    <!-- Tanda tangan -->
    <div class="grid grid-cols-2 gap-12 mt-12 pt-6">
      <div class="text-center">
        <p class="text-[11px] text-slate-500 mb-12">Disetujui oleh,</p>
        <div class="border-t border-slate-400 pt-1">
          <p class="text-[12px] font-semibold"><%= generatedBy?.name || '—' %></p>
          <p class="text-[10px] text-slate-500"><%= studio.name %></p>
        </div>
      </div>
      <div class="text-center">
        <p class="text-[11px] text-slate-500 mb-12">Diterima oleh,</p>
        <div class="border-t border-slate-400 pt-1">
          <p class="text-[12px] font-semibold"><%= staff.name %></p>
          <p class="text-[10px] text-slate-500">Karyawan</p>
        </div>
      </div>
    </div>

    <p class="text-center text-[10px] text-slate-400 mt-10">
      Dokumen ini dihasilkan secara otomatis oleh sistem ISH Invoice — <%= todayStr %>.
    </p>
  </div>
</body>
</html>
