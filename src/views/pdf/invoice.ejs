<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Invoice — <%= invoice.invoice_number %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>body { font-family: 'Inter', sans-serif; }</style>
</head>
<body class="bg-white text-gray-900 p-8">
  <div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="flex justify-between items-start mb-8 pb-6 border-b-2 border-indigo-600">
      <div>
        <% if (invoice.logo_path) { %>
          <img src="<%= invoice.logo_path %>" class="h-12 mb-2" alt="">
        <% } %>
        <h2 class="text-xl font-bold"><%= invoice.business_name %></h2>
        <% if (invoice.business_address) { %><p class="text-sm text-gray-500 whitespace-pre-line"><%= invoice.business_address %></p><% } %>
        <% if (invoice.business_email) { %><p class="text-sm text-gray-500"><%= invoice.business_email %></p><% } %>
        <% if (invoice.business_phone) { %><p class="text-sm text-gray-500"><%= invoice.business_phone %></p><% } %>
      </div>
      <div class="text-right">
        <h1 class="text-3xl font-bold text-indigo-600">INVOICE</h1>
        <p class="text-sm text-gray-500 mt-1"><%= invoice.invoice_number %></p>
      </div>
    </div>

    <!-- Bill To & Invoice Meta -->
    <div class="grid grid-cols-2 gap-8 mb-8">
      <div>
        <p class="text-xs text-gray-500 uppercase font-semibold mb-1">Bill To</p>
        <p class="font-semibold"><%= invoice.client_name %></p>
        <% if (invoice.company) { %><p class="text-sm text-gray-600"><%= invoice.company %></p><% } %>
        <% if (invoice.client_email) { %><p class="text-sm text-gray-500"><%= invoice.client_email %></p><% } %>
        <% if (invoice.client_phone) { %><p class="text-sm text-gray-500"><%= invoice.client_phone %></p><% } %>
        <% if (invoice.client_address) { %><p class="text-sm text-gray-500 whitespace-pre-line"><%= invoice.client_address %></p><% } %>
      </div>
      <div class="text-right">
        <div class="space-y-1">
          <p class="text-sm"><span class="text-gray-500">Invoice Date:</span> <span class="font-medium"><%= invoice.issue_date ? new Date(invoice.issue_date).toLocaleDateString('en-GB') : '-' %></span></p>
          <% if (invoice.due_date) { %><p class="text-sm"><span class="text-gray-500">Due Date:</span> <span class="font-medium"><%= new Date(invoice.due_date).toLocaleDateString('en-GB') %></span></p><% } %>
          <p class="text-sm"><span class="text-gray-500">Project:</span> <span class="font-medium"><%= invoice.project_name %></span></p>
        </div>
      </div>
    </div>

    <!-- Line Items -->
    <table class="w-full text-sm mb-6">
      <thead>
        <tr class="border-b-2 border-gray-300">
          <th class="text-left py-2 font-semibold">#</th>
          <th class="text-left py-2 font-semibold">Description</th>
          <th class="text-right py-2 font-semibold">Qty</th>
          <th class="text-right py-2 font-semibold">Unit Price</th>
          <th class="text-right py-2 font-semibold">Amount (<%= invoice.currency || 'MYR' %>)</th>
        </tr>
      </thead>
      <tbody>
        <% items.forEach((it, i) => { %>
          <tr class="border-b border-gray-200">
            <td class="py-2"><%= i + 1 %></td>
            <td class="py-2">
              <% if (it.phase_label) { %><span class="text-gray-400 text-xs"><%= it.phase_label %> · </span><% } %>
              <%= it.description %>
            </td>
            <td class="py-2 text-right"><%= it.quantity %></td>
            <td class="py-2 text-right"><%= parseFloat(it.unit_price).toLocaleString('en-MY',{minimumFractionDigits:2}) %></td>
            <td class="py-2 text-right font-medium"><%= parseFloat(it.amount).toLocaleString('en-MY',{minimumFractionDigits:2}) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <!-- Totals -->
    <div class="flex justify-end mb-8">
      <div class="w-72 space-y-2">
        <div class="flex justify-between text-sm">
          <span class="text-gray-600">Subtotal</span>
          <span class="font-medium"><%= parseFloat(invoice.subtotal).toLocaleString('en-MY',{minimumFractionDigits:2}) %></span>
        </div>
        <% if (parseFloat(invoice.tax_percent) > 0) { %>
        <div class="flex justify-between text-sm">
          <span class="text-gray-600">Tax (<%= invoice.tax_percent %>%)</span>
          <span class="font-medium"><%= parseFloat(invoice.tax_amount).toLocaleString('en-MY',{minimumFractionDigits:2}) %></span>
        </div>
        <% } %>
        <div class="flex justify-between pt-2 border-t-2 border-gray-800">
          <span class="font-bold text-base">Total</span>
          <span class="font-bold text-lg"><%= invoice.currency || 'MYR' %> <%= parseFloat(invoice.total).toLocaleString('en-MY',{minimumFractionDigits:2}) %></span>
        </div>
        <% if (parseFloat(invoice.amount_paid) > 0) { %>
        <div class="flex justify-between text-sm text-emerald-600">
          <span>Paid</span>
          <span>- <%= parseFloat(invoice.amount_paid).toLocaleString('en-MY',{minimumFractionDigits:2}) %></span>
        </div>
        <div class="flex justify-between text-sm font-bold text-red-600">
          <span>Balance Due</span>
          <span><%= invoice.currency || 'MYR' %> <%= parseFloat(invoice.balance_due).toLocaleString('en-MY',{minimumFractionDigits:2}) %></span>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Milestones -->
    <% if (milestones && milestones.length > 0) { %>
    <div class="mb-8">
      <p class="text-sm font-semibold mb-2 text-gray-700">Payment Schedule</p>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-gray-300">
            <th class="text-left py-1.5 font-medium text-gray-600">Milestone</th>
            <th class="text-right py-1.5 font-medium text-gray-600">%</th>
            <th class="text-right py-1.5 font-medium text-gray-600">Amount</th>
            <th class="text-left py-1.5 font-medium text-gray-600">Due</th>
            <th class="text-center py-1.5 font-medium text-gray-600">Status</th>
          </tr>
        </thead>
        <tbody>
          <% milestones.forEach(m => { %>
            <tr class="border-b border-gray-100">
              <td class="py-1.5"><%= m.label %></td>
              <td class="py-1.5 text-right"><%= m.percent %>%</td>
              <td class="py-1.5 text-right font-medium"><%= parseFloat(m.amount).toLocaleString('en-MY',{minimumFractionDigits:2}) %></td>
              <td class="py-1.5"><%= m.due_date ? new Date(m.due_date).toLocaleDateString('en-GB') : '-' %></td>
              <td class="py-1.5 text-center capitalize"><%= m.status %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>

    <!-- Bank Details -->
    <% if (invoice.bank_name) { %>
    <div class="bg-gray-50 rounded-lg p-5 border border-gray-200 mb-8">
      <p class="text-sm font-semibold text-gray-700 mb-2">Payment Details</p>
      <div class="grid grid-cols-2 gap-2 text-sm">
        <p class="text-gray-500">Bank</p><p class="font-medium"><%= invoice.bank_name %></p>
        <p class="text-gray-500">Account Name</p><p class="font-medium"><%= invoice.bank_account_name %></p>
        <p class="text-gray-500">Account Number</p><p class="font-medium font-mono"><%= invoice.bank_account_number %></p>
      </div>
    </div>
    <% } %>

    <!-- Notes -->
    <% if (invoice.notes) { %>
    <div class="mb-8">
      <p class="text-sm font-semibold text-gray-700 mb-1">Notes</p>
      <p class="text-sm text-gray-600 whitespace-pre-line"><%= invoice.notes %></p>
    </div>
    <% } %>

    <p class="text-xs text-gray-400 text-center border-t border-gray-200 pt-4">
      Generated by Shopee Report · <%= new Date().toLocaleDateString('en-GB') %>
    </p>
  </div>
</body>
</html>
