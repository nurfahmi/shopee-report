<%
  const fmtIDR = n => (Math.floor(Math.max(0, parseFloat(n||0)) / 100) * 100).toLocaleString('id-ID');
  const monthName = (m) => new Date(2000, m-1, 1).toLocaleDateString('en-GB', { month: 'long' });
  const currentLabel = `${monthName(currentM)} ${currentY}`;
  // Find current month's data (if it exists)
  const cur = months.find(x => x.year === currentY && x.month === currentM) || { income: 0, payroll: 0, expenses: 0, net: 0 };
%>

<div class="max-w-6xl">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-5">
    <div class="flex items-center gap-3 min-w-0">
      <a href="/finance" class="text-slate-400 hover:text-slate-700 shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      </a>
      <div>
        <h1 class="text-xl sm:text-2xl font-bold text-slate-900 tracking-tight"><%= studio.name %></h1>
        <p class="text-slate-500 text-sm mt-1">
          <%= months.length %> month<%= months.length === 1 ? '' : 's' %> on file · all amounts in IDR
        </p>
      </div>
    </div>
    <div class="flex gap-2 flex-wrap">
      <a href="/finance/<%= studio.id %>/staff" class="inline-flex items-center gap-1.5 px-3 py-2 bg-white ring-1 ring-slate-200 hover:ring-slate-300 text-slate-700 rounded-lg text-[11px] font-semibold tracking-wide uppercase transition">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        Manage Staff
      </a>
      <a href="/finance/<%= studio.id %>/<%= currentY %>/<%= String(currentM).padStart(2,'0') %>" class="inline-flex items-center gap-1.5 px-3 py-2 bg-slate-900 hover:bg-slate-800 text-white rounded-lg text-[11px] font-semibold tracking-wide uppercase shadow-sm transition whitespace-nowrap">
        Open <%= currentLabel %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- Hero KPIs: this month -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-5">
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-emerald-200 p-4 sm:p-5">
      <p class="text-[10px] font-semibold text-emerald-600 uppercase tracking-wider"><%= currentLabel %> · Income</p>
      <p class="text-lg sm:text-xl font-bold text-emerald-700 mt-1.5 tabular-nums">IDR <%= fmtIDR(cur.income) %></p>
      <p class="text-[10px] text-emerald-500/70 mt-1">from Shopee distributions</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4 sm:p-5">
      <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider">Payroll</p>
      <p class="text-lg sm:text-xl font-bold text-slate-900 mt-1.5 tabular-nums">IDR <%= fmtIDR(cur.payroll) %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4 sm:p-5">
      <p class="text-[10px] font-semibold text-rose-500 uppercase tracking-wider">Expenses</p>
      <p class="text-lg sm:text-xl font-bold text-rose-700 mt-1.5 tabular-nums">IDR <%= fmtIDR(cur.expenses) %></p>
    </div>
    <% const cn = cur.net >= 0 ? 'emerald' : 'rose'; %>
    <div class="bg-white rounded-xl shadow-sm ring-2 ring-<%= cn %>-300 p-4 sm:p-5">
      <p class="text-[10px] font-semibold text-<%= cn %>-600 uppercase tracking-wider">Net P&amp;L</p>
      <p class="text-lg sm:text-xl font-bold text-<%= cn %>-700 mt-1.5 tabular-nums"><%= cur.net < 0 ? '−' : '' %>IDR <%= fmtIDR(Math.abs(cur.net)) %></p>
      <p class="text-[10px] text-slate-400 mt-1">income − outflow</p>
    </div>
  </div>

  <!-- Monthly history table -->
  <% if (!months.length) { %>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-10 text-center text-slate-400 text-sm">
      No monthly activity yet for this studio.
      <a href="/finance/<%= studio.id %>/<%= currentY %>/<%= String(currentM).padStart(2,'0') %>" class="text-indigo-600 hover:underline font-semibold">Open <%= currentLabel %></a>
      to start.
    </div>
  <% } else { %>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-[13px]">
          <thead class="bg-slate-50/80 border-b border-slate-200/70 text-slate-500 text-[10px] uppercase tracking-wider">
            <tr>
              <th class="text-left  px-3 py-2.5 font-semibold">Month</th>
              <th class="text-right px-3 py-2.5 font-semibold">Income</th>
              <th class="text-right px-3 py-2.5 font-semibold hidden sm:table-cell">Payroll</th>
              <th class="text-right px-3 py-2.5 font-semibold hidden sm:table-cell">Expenses</th>
              <th class="text-right px-3 py-2.5 font-semibold">Net P&amp;L</th>
              <th class="px-3 py-2.5"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% months.forEach(m => {
                 const mn = m.net >= 0 ? 'emerald' : 'rose';
            %>
              <tr class="hover:bg-slate-50/60 transition-colors cursor-pointer" onclick="window.location='/finance/<%= studio.id %>/<%= m.year %>/<%= String(m.month).padStart(2,'0') %>'">
                <td class="px-3 py-2.5 align-top">
                  <p class="font-semibold text-slate-900 leading-tight"><%= m.label %></p>
                  <p class="text-[10px] text-slate-500 mt-0.5">
                    <% if (m.shopeeCount > 0) { %><%= m.shopeeCount %> Shopee<% } %>
                    <% if (m.shopeeCount > 0 && m.otherIncome > 0) { %> · <% } %>
                    <% if (m.otherIncome > 0) { %>+ other income<% } %>
                    <% if (!m.shopeeCount && !m.otherIncome && !m.hasReport) { %>income only<% } %>
                  </p>
                </td>
                <td class="px-3 py-2.5 text-right text-emerald-700 font-semibold tabular-nums">IDR <%= fmtIDR(m.income) %></td>
                <td class="px-3 py-2.5 text-right text-slate-600 tabular-nums hidden sm:table-cell">IDR <%= fmtIDR(m.payroll) %></td>
                <td class="px-3 py-2.5 text-right text-rose-600 tabular-nums hidden sm:table-cell">IDR <%= fmtIDR(m.expenses) %></td>
                <td class="px-3 py-2.5 text-right">
                  <span class="font-bold text-<%= mn %>-700 tabular-nums"><%= m.net < 0 ? '−' : '' %>IDR <%= fmtIDR(Math.abs(m.net)) %></span>
                </td>
                <td class="px-3 py-2.5 text-right">
                  <a href="/finance/<%= studio.id %>/<%= m.year %>/<%= String(m.month).padStart(2,'0') %>" onclick="event.stopPropagation()" class="inline-flex items-center gap-1 px-3 py-1.5 bg-slate-900 hover:bg-slate-800 text-white text-[11px] font-semibold tracking-wide rounded-lg shadow-sm whitespace-nowrap transition">
                    Open
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
          <% if (months.length > 1) { %>
            <tfoot class="bg-slate-50/80 border-t border-slate-200/70 font-semibold tabular-nums">
              <tr>
                <td class="px-3 py-2.5 text-slate-700 text-[11px] uppercase tracking-wider">All-time</td>
                <td class="px-3 py-2.5 text-right text-emerald-700">IDR <%= fmtIDR(totals.income) %></td>
                <td class="px-3 py-2.5 text-right text-slate-700 hidden sm:table-cell">IDR <%= fmtIDR(totals.payroll) %></td>
                <td class="px-3 py-2.5 text-right text-rose-700 hidden sm:table-cell">IDR <%= fmtIDR(totals.expenses) %></td>
                <% const tn = totals.net >= 0 ? 'emerald' : 'rose'; %>
                <td class="px-3 py-2.5 text-right text-<%= tn %>-700"><%= totals.net < 0 ? '−' : '' %>IDR <%= fmtIDR(Math.abs(totals.net)) %></td>
                <td></td>
              </tr>
            </tfoot>
          <% } %>
        </table>
      </div>
    </div>
  <% } %>

  <!-- Open another month -->
  <div class="mt-4 bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4">
    <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider mb-2">Open another month</p>
    <form method="POST" action="/finance/<%= studio.id %>/period/create" class="flex flex-wrap items-end gap-2">
      <div>
        <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Year</label>
        <input type="number" name="year" min="2020" max="2100" value="<%= currentY %>" required
          class="w-24 px-3 py-2 border border-slate-300 rounded-lg text-sm tabular-nums focus:ring-2 focus:ring-slate-900 outline-none">
      </div>
      <div>
        <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Month</label>
        <select name="month" required class="px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 outline-none">
          <% for (let i = 1; i <= 12; i++) { %>
            <option value="<%= i %>" <%= i === currentM ? 'selected' : '' %>><%= monthName(i) %></option>
          <% } %>
        </select>
      </div>
      <button type="submit" class="px-4 py-2 bg-slate-900 hover:bg-slate-800 text-white text-[11px] font-semibold tracking-wide uppercase rounded-lg shadow-sm">Open / Create</button>
    </form>
  </div>
</div>
