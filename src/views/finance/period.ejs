<%
  const fmtIDR = n => (Math.floor(Math.max(0, parseFloat(n||0)) / 100) * 100).toLocaleString('id-ID');
  const fmtIDRRaw = n => (n == null || n === '') ? '' : (Math.floor(Math.max(0, parseFloat(n)) / 100) * 100).toLocaleString('id-ID');
  const yyyy = period.year;
  const mm   = String(period.month).padStart(2, '0');
  const sId  = studio.id;
  const COMMON_CATEGORIES = ['Internet','Electric','Water','Rent','Office Supplies','Software','Transportation','Other'];

  // Today's date for expense default
  const today = new Date();
  const todayStr = `${today.getFullYear()}-${String(today.getMonth()+1).padStart(2,'0')}-${String(today.getDate()).padStart(2,'0')}`;
  const netCls = totals.net >= 0 ? 'emerald' : 'rose';
%>

<div class="max-w-6xl">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-5">
    <div class="flex items-center gap-3 min-w-0">
      <a href="/finance/<%= sId %>" class="text-slate-400 hover:text-slate-700 shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      </a>
      <div>
        <h1 class="text-xl sm:text-2xl font-bold text-slate-900 tracking-tight"><%= studio.name %> · <%= period.label %></h1>
        <p class="text-slate-500 text-sm mt-1">
          <%= incomeEntries.length %> distribution<%= incomeEntries.length === 1 ? '' : 's' %>
          · <%= staffPayouts.length %> staff
          · <%= expenses.length %> expense<%= expenses.length === 1 ? '' : 's' %>
        </p>
      </div>
    </div>
    <div class="text-right">
      <p class="text-[10px] font-semibold text-<%= netCls %>-600 uppercase tracking-wider">Net P&amp;L</p>
      <p class="text-2xl font-bold text-<%= netCls %>-700 tabular-nums"><%= totals.net < 0 ? '−' : '' %>IDR <%= fmtIDR(Math.abs(totals.net)) %></p>
    </div>
  </div>

  <!-- Hero KPIs: Income · Payroll · Expenses · Net -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-5">
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-emerald-200 p-4 sm:p-5"
         data-income-idr="<%= totals.income %>" data-expenses-idr="<%= totals.expenses %>">
      <p class="text-[10px] font-semibold text-emerald-600 uppercase tracking-wider">Income</p>
      <p class="text-lg sm:text-xl font-bold text-emerald-700 mt-1.5 tabular-nums">IDR <%= fmtIDR(totals.income) %></p>
      <p class="text-[10px] text-emerald-500/70 mt-1"><%= incomeEntries.length %> distribution<%= incomeEntries.length === 1 ? '' : 's' %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4 sm:p-5">
      <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider">Payroll</p>
      <p class="text-lg sm:text-xl font-bold text-slate-900 mt-1.5 tabular-nums js-payroll-hero">IDR <%= fmtIDR(totals.payroll) %></p>
      <p class="text-[10px] text-slate-400 mt-1"><%= staffPayouts.length %> staff</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4 sm:p-5">
      <p class="text-[10px] font-semibold text-rose-500 uppercase tracking-wider">Expenses</p>
      <p class="text-lg sm:text-xl font-bold text-rose-700 mt-1.5 tabular-nums">IDR <%= fmtIDR(totals.expenses) %></p>
      <p class="text-[10px] text-rose-500/70 mt-1"><%= expenses.length %> line items</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm ring-2 ring-<%= netCls %>-300 p-4 sm:p-5 js-net-card">
      <p class="text-[10px] font-semibold text-<%= netCls %>-600 uppercase tracking-wider js-net-label">Net P&amp;L</p>
      <p class="text-lg sm:text-xl font-bold text-<%= netCls %>-700 mt-1.5 tabular-nums js-net-hero"><%= totals.net < 0 ? '−' : '' %>IDR <%= fmtIDR(Math.abs(totals.net)) %></p>
      <p class="text-[10px] text-slate-400 mt-1">income − payroll − expenses</p>
    </div>
  </div>

  <!-- ═══════════ INCOME (auto-pulled from Shopee distributions) ═══════════ -->
  <div class="mb-6">
    <h2 class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider mb-2 px-1 flex items-center justify-between">
      <span>Income — distributions received</span>
      <span class="text-[10px] text-slate-400">auto-pulled from Shopee payouts marked distributed/completed in <%= period.label %></span>
    </h2>
    <% if (!incomeEntries.length) { %>
      <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-8 text-center text-slate-400 text-sm">
        No Shopee distributions to <%= studio.name %> in <%= period.label %> yet.
      </div>
    <% } else { %>
      <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-[13px]">
            <thead class="bg-slate-50/80 border-b border-slate-200/70 text-slate-500 text-[10px] uppercase tracking-wider">
              <tr>
                <th class="text-left  px-3 py-2.5 font-semibold">Affiliate / Invoice</th>
                <th class="text-left  px-2 py-2.5 font-semibold hidden md:table-cell">Earning Period</th>
                <th class="text-right px-2 py-2.5 font-semibold hidden sm:table-cell">FX</th>
                <th class="text-right px-2 py-2.5 font-semibold hidden sm:table-cell">Distributed At</th>
                <th class="text-right px-3 py-2.5 font-semibold">Income (IDR)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% incomeEntries.forEach(e => {
                   const dt = e.updated_at ? new Date(e.updated_at) : null;
                   const ds = dt ? `${String(dt.getDate()).padStart(2,'0')}/${String(dt.getMonth()+1).padStart(2,'0')}/${dt.getFullYear()}` : '—';
              %>
                <tr class="hover:bg-slate-50/60 transition-colors cursor-pointer" onclick="window.location='/shopee/payouts/<%= e.id %>'">
                  <td class="px-3 py-2.5 align-top">
                    <p class="font-semibold text-slate-900 leading-tight"><%= e.affiliate_name || '—' %></p>
                    <p class="text-[10px] text-slate-400 mt-0.5 font-mono"><%= e.invoice_number || `#${e.id}` %></p>
                  </td>
                  <td class="px-2 py-2.5 align-top text-[11px] text-slate-500 hidden md:table-cell"><%= e.period_description || '—' %></td>
                  <td class="px-2 py-2.5 align-top text-right text-[11px] text-slate-500 tabular-nums hidden sm:table-cell font-mono">
                    <% if (e.actual_fx_rate) { %><%= parseFloat(e.actual_fx_rate).toLocaleString() %><% } else { %>—<% } %>
                  </td>
                  <td class="px-2 py-2.5 align-top text-right text-[11px] text-slate-500 tabular-nums hidden sm:table-cell"><%= ds %></td>
                  <td class="px-3 py-2.5 align-top text-right">
                    <span class="font-semibold text-emerald-700 tabular-nums">IDR <%= fmtIDR(e.actual_distributed_idr) %></span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
            <tfoot class="bg-slate-50/80 border-t border-slate-200/70 font-semibold tabular-nums">
              <tr>
                <td class="px-3 py-2.5 text-slate-700 text-[11px] uppercase tracking-wider">Total Income</td>
                <td class="px-2 py-2.5 hidden md:table-cell"></td>
                <td class="px-2 py-2.5 hidden sm:table-cell"></td>
                <td class="px-2 py-2.5 hidden sm:table-cell"></td>
                <td class="px-3 py-2.5 text-right text-emerald-700">IDR <%= fmtIDR(totals.income) %></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    <% } %>
  </div>

  <!-- ═══════════ STAFF PAYROLL ═══════════ -->
  <div class="mb-6">
    <h2 class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider mb-2 px-1 flex items-center justify-between gap-3 flex-wrap">
      <span>Staff Payroll</span>
      <span class="flex items-center gap-3">
        <% if (staffPayouts.length > 0) { %>
          <button type="button" id="js-save-all" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white text-[10.5px] font-semibold tracking-wide uppercase rounded-lg shadow-sm transition disabled:opacity-50">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="js-save-all-label">Save All</span>
          </button>
        <% } %>
        <a href="/finance/<%= sId %>/staff" class="text-[10px] text-indigo-600 hover:text-indigo-700">Manage staff →</a>
      </span>
    </h2>

    <% if (!staffPayouts.length) { %>
      <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-8 text-center text-slate-400 text-sm">
        No active staff yet.
        <a href="/finance/<%= sId %>/staff" class="text-indigo-600 hover:underline font-semibold">Add staff</a>
        to start tracking payouts.
      </div>
    <% } else { %>
      <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-[13px]">
            <thead class="bg-slate-50/80 border-b border-slate-200/70 text-slate-500 text-[10px] uppercase tracking-wider">
              <tr>
                <th class="text-left  px-3 py-2.5 font-semibold">Staff</th>
                <th class="text-left  px-2 py-2.5 font-semibold hidden md:table-cell">Type</th>
                <th class="text-right px-2 py-2.5 font-semibold hidden lg:table-cell">Rate</th>
                <th class="text-right px-2 py-2.5 font-semibold">Hours</th>
                <th class="text-right px-2 py-2.5 font-semibold">Days</th>
                <th class="text-right px-2 py-2.5 font-semibold hidden sm:table-cell">Lunch (×days)</th>
                <th class="text-right px-2 py-2.5 font-semibold">Payout (IDR)</th>
                <th class="px-2 py-2.5"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% staffPayouts.forEach(p => {
                   const isHourly = (p.salary_type_snapshot || p.current_salary_type) === 'hourly';
                   const hr  = parseFloat(p.hourly_rate_snapshot_idr    || p.current_hourly_rate    || 0);
                   const ms  = parseFloat(p.monthly_salary_snapshot_idr || p.current_monthly_salary || 0);
                   const cb  = parseFloat(p.lunch_cashback_snapshot_idr || p.current_lunch_cashback || 0);
                   const lunchTotal = (parseInt(p.days_worked || 0) * cb);
              %>
                <tr class="hover:bg-slate-50/60 transition-colors">
                  <td class="px-3 py-2.5 align-top">
                    <p class="font-semibold text-slate-900 leading-tight"><%= p.staff_name %></p>
                    <% if (p.role_title) { %>
                      <p class="text-[10px] text-slate-400 mt-0.5"><%= p.role_title %></p>
                    <% } %>
                    <% if (!p.staff_is_active) { %>
                      <span class="inline-block mt-0.5 px-1 py-0.5 rounded text-[9px] font-semibold bg-slate-100 text-slate-500">INACTIVE</span>
                    <% } %>
                  </td>
                  <td class="px-2 py-2.5 align-top text-slate-600 text-[11px] hidden md:table-cell">
                    <%= isHourly ? 'Hourly' : 'Fixed' %>
                  </td>
                  <td class="px-2 py-2.5 align-top text-right text-slate-600 text-[11px] tabular-nums hidden lg:table-cell">
                    <% if (isHourly) { %>
                      IDR <%= fmtIDRRaw(hr) %>/h
                    <% } else { %>
                      IDR <%= fmtIDRRaw(ms) %>/mo
                    <% } %>
                  </td>
                  <!--
                    Inline form spans across cells via the HTML5 `form="..."` attr on each input.
                    The form itself sits inside one cell; inputs in other cells reference it by id.
                    Native browser submit behavior ties them together — no JS mirror needed.
                  -->
                  <td class="px-2 py-2.5 align-top text-right">
                    <form id="payout-form-<%= p.staff_id %>" method="POST" action="/finance/<%= sId %>/<%= yyyy %>/<%= mm %>/payout"
                          class="js-payout-form contents" data-staff="<%= p.staff_id %>"
                          data-rate="<%= hr %>" data-monthly="<%= ms %>" data-cashback="<%= cb %>"
                          data-type="<%= isHourly ? 'hourly' : 'fixed' %>"
                          data-initial-amount="<%= p.calculated_amount_idr || 0 %>">
                      <input type="hidden" name="staff_id" value="<%= p.staff_id %>" form="payout-form-<%= p.staff_id %>">
                    </form>
                    <input type="number" name="hours_worked" step="0.5" min="0" value="<%= parseFloat(p.hours_worked || 0) %>" <%= isHourly ? '' : 'disabled' %>
                      form="payout-form-<%= p.staff_id %>"
                      class="w-20 px-2 py-1 border border-slate-300 rounded-md text-[12.5px] text-right tabular-nums focus:ring-2 focus:ring-slate-900 outline-none js-hours <%= isHourly ? '' : 'opacity-40' %>"
                      data-staff="<%= p.staff_id %>">
                  </td>
                  <td class="px-2 py-2.5 align-top text-right">
                    <input type="number" name="days_worked" min="0" max="31" value="<%= parseInt(p.days_worked || 0) %>"
                      form="payout-form-<%= p.staff_id %>"
                      class="w-16 px-2 py-1 border border-slate-300 rounded-md text-[12.5px] text-right tabular-nums focus:ring-2 focus:ring-slate-900 outline-none js-days"
                      data-staff="<%= p.staff_id %>">
                  </td>
                  <td class="px-2 py-2.5 align-top text-right text-[11px] text-slate-500 tabular-nums hidden sm:table-cell">
                    <% if (cb > 0) { %>
                      <span class="js-lunch-display" data-staff="<%= p.staff_id %>">IDR <%= fmtIDRRaw(lunchTotal) %></span>
                    <% } else { %>
                      <span class="text-slate-300">—</span>
                    <% } %>
                  </td>
                  <td class="px-2 py-2.5 align-top text-right">
                    <span class="font-semibold text-emerald-700 tabular-nums js-amount"
                          data-staff="<%= p.staff_id %>"
                          data-amount="<%= p.calculated_amount_idr || 0 %>">IDR <%= fmtIDRRaw(p.calculated_amount_idr) %></span>
                  </td>
                  <td class="px-2 py-2.5 align-top text-right">
                    <button type="submit" form="payout-form-<%= p.staff_id %>"
                            class="px-2.5 py-1 bg-slate-900 hover:bg-slate-800 text-white text-[10px] font-semibold tracking-wide uppercase rounded-md shadow-sm whitespace-nowrap">Save</button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
            <tfoot class="bg-slate-50/80 border-t border-slate-200/70 font-semibold tabular-nums">
              <tr>
                <td class="px-3 py-2.5 text-slate-700 text-[11px] uppercase tracking-wider">Total Payroll</td>
                <td class="px-2 py-2.5 hidden md:table-cell"></td>
                <td class="px-2 py-2.5 hidden lg:table-cell"></td>
                <td class="px-2 py-2.5"></td>
                <td class="px-2 py-2.5"></td>
                <td class="px-2 py-2.5 hidden sm:table-cell"></td>
                <td class="px-2 py-2.5 text-right text-emerald-700 js-payroll-total-foot">IDR <%= fmtIDR(totals.payroll) %></td>
                <td class="px-2 py-2.5"></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    <% } %>
  </div>

  <!-- ═══════════ EXPENSES ═══════════ -->
  <div class="mb-6">
    <h2 class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider mb-2 px-1">Expenses</h2>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 overflow-hidden">
      <!-- Add expense form -->
      <div class="p-4 sm:p-5 border-b border-slate-100 bg-slate-50/40">
        <form method="POST" action="/finance/<%= sId %>/<%= yyyy %>/<%= mm %>/expense" class="grid grid-cols-1 sm:grid-cols-12 gap-2 items-end">
          <div class="sm:col-span-3">
            <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Category</label>
            <input list="expense-categories" type="text" name="category" required placeholder="e.g. Internet"
              class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 outline-none">
            <datalist id="expense-categories">
              <% COMMON_CATEGORIES.forEach(c => { %><option value="<%= c %>"><% }) %>
            </datalist>
          </div>
          <div class="sm:col-span-4">
            <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Description</label>
            <input type="text" name="description" placeholder="optional notes" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 outline-none">
          </div>
          <div class="sm:col-span-2">
            <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Date</label>
            <input type="date" name="expense_date" value="<%= todayStr %>" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm tabular-nums focus:ring-2 focus:ring-slate-900 outline-none">
          </div>
          <div class="sm:col-span-2">
            <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1">Amount (IDR)</label>
            <input type="number" name="amount_idr" step="100" min="0" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm tabular-nums focus:ring-2 focus:ring-slate-900 outline-none">
          </div>
          <div class="sm:col-span-1">
            <button type="submit" class="w-full px-3 py-2 bg-slate-900 hover:bg-slate-800 text-white text-[11px] font-semibold tracking-wide uppercase rounded-lg shadow-sm">Add</button>
          </div>
        </form>
      </div>

      <% if (!expenses.length) { %>
        <div class="p-8 text-center text-slate-400 text-sm">No expenses recorded for this month.</div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full text-[13px]">
            <thead class="bg-slate-50/80 border-b border-slate-200/70 text-slate-500 text-[10px] uppercase tracking-wider">
              <tr>
                <th class="text-left  px-3 py-2.5 font-semibold">Category</th>
                <th class="text-left  px-2 py-2.5 font-semibold hidden sm:table-cell">Description</th>
                <th class="text-left  px-2 py-2.5 font-semibold hidden md:table-cell">Date</th>
                <th class="text-right px-2 py-2.5 font-semibold">Amount (IDR)</th>
                <th class="px-2 py-2.5"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% expenses.forEach(e => {
                   const d = e.expense_date ? new Date(e.expense_date) : null;
                   const ds = d ? `${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}/${d.getFullYear()}` : '—';
              %>
                <tr class="hover:bg-slate-50/60 transition-colors">
                  <td class="px-3 py-2.5 align-top">
                    <p class="font-semibold text-slate-900 leading-tight"><%= e.category %></p>
                    <p class="text-[10px] text-slate-400 sm:hidden mt-0.5"><%= e.description || '' %></p>
                  </td>
                  <td class="px-2 py-2.5 align-top text-slate-600 text-[11px] hidden sm:table-cell"><%= e.description || '—' %></td>
                  <td class="px-2 py-2.5 align-top text-slate-500 text-[11px] tabular-nums hidden md:table-cell"><%= ds %></td>
                  <td class="px-2 py-2.5 align-top text-right">
                    <span class="font-semibold text-rose-700 tabular-nums">IDR <%= fmtIDR(e.amount_idr) %></span>
                  </td>
                  <td class="px-2 py-2.5 align-top text-right">
                    <form method="POST" action="/finance/<%= sId %>/<%= yyyy %>/<%= mm %>/expense/<%= e.id %>/delete" onsubmit="return confirm('Delete this expense?')" class="inline">
                      <button type="submit" class="text-slate-400 hover:text-rose-600 text-[11px]" title="Delete">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22m-9 0V5a2 2 0 00-2-2h-2a2 2 0 00-2 2v2"/></svg>
                      </button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
            <tfoot class="bg-slate-50/80 border-t border-slate-200/70 font-semibold tabular-nums">
              <tr>
                <td class="px-3 py-2.5 text-slate-700 text-[11px] uppercase tracking-wider">Total Expenses</td>
                <td class="px-2 py-2.5 hidden sm:table-cell"></td>
                <td class="px-2 py-2.5 hidden md:table-cell"></td>
                <td class="px-2 py-2.5 text-right text-rose-700">IDR <%= fmtIDR(totals.expenses) %></td>
                <td class="px-2 py-2.5"></td>
              </tr>
            </tfoot>
          </table>
        </div>
      <% } %>
    </div>
  </div>

  <!-- P&L summary banner (live-updates as you type hours/days) -->
  <div class="js-pl-banner bg-gradient-to-br from-<%= netCls %>-50 to-white ring-1 ring-<%= netCls %>-200 rounded-xl p-4 sm:p-5">
    <div class="flex items-center justify-between gap-4 flex-wrap">
      <div>
        <p class="text-[10px] font-semibold text-<%= netCls %>-600 uppercase tracking-wider js-pl-banner-label"><%= studio.name %> · Net P&amp;L</p>
        <p class="text-[11px] text-slate-500 mt-0.5">
          income (IDR <%= fmtIDR(totals.income) %>) −
          payroll (<span class="js-payroll-banner">IDR <%= fmtIDR(totals.payroll) %></span>) −
          expenses (IDR <%= fmtIDR(totals.expenses) %>)
        </p>
      </div>
      <p class="text-2xl sm:text-3xl font-bold text-<%= netCls %>-700 tabular-nums whitespace-nowrap js-net-banner">
        <%= totals.net < 0 ? '−' : '' %>IDR <%= fmtIDR(Math.abs(totals.net)) %>
      </p>
    </div>
  </div>

  <script>
    // Live recalculation when ID admin types hours/days. Uses the snapshot rate
    // baked into form data attrs so what shows == what gets saved. The footer
    // total + hero KPI + P&L banner all update in real time.
    const floorIdr = n => Math.floor(Math.max(0, n) / 100) * 100;
    const fmtIdrStr = n => floorIdr(n).toLocaleString('id-ID');

    const incomeIdr   = parseFloat(document.querySelector('[data-income-idr]')?.dataset.incomeIdr) || 0;
    const expensesIdr = parseFloat(document.querySelector('[data-expenses-idr]')?.dataset.expensesIdr) || 0;

    const payrollHero  = document.querySelector('.js-payroll-hero');
    const payrollFoot  = document.querySelector('.js-payroll-total-foot');
    const payrollBanner= document.querySelector('.js-payroll-banner');
    const netCard      = document.querySelector('.js-net-card');
    const netHero      = document.querySelector('.js-net-hero');
    const netBanner    = document.querySelector('.js-net-banner');
    const plBanner     = document.querySelector('.js-pl-banner');

    function applyNetClasses(net) {
      // Swap green/red classes on the net P&L card + banner depending on sign.
      const positive = net >= 0;
      const old = positive ? 'rose' : 'emerald';
      const cur = positive ? 'emerald' : 'rose';
      [netCard, plBanner].forEach(el => {
        if (!el) return;
        el.className = el.className
          .replace(new RegExp('ring-' + old + '-(\\d+)', 'g'), 'ring-' + cur + '-$1')
          .replace(new RegExp('from-' + old + '-(\\d+)', 'g'), 'from-' + cur + '-$1');
      });
      [netHero, netBanner, document.querySelector('.js-net-label'), document.querySelector('.js-pl-banner-label')].forEach(el => {
        if (!el) return;
        el.className = el.className
          .replace(new RegExp('text-' + old + '-(\\d+)', 'g'), 'text-' + cur + '-$1');
      });
    }

    function recalcTotals() {
      let total = 0;
      document.querySelectorAll('.js-amount').forEach(c => {
        total += parseFloat(c.dataset.amount) || 0;
      });
      const flooredTotal = floorIdr(total);
      if (payrollHero)   payrollHero.textContent   = 'IDR ' + fmtIdrStr(flooredTotal);
      if (payrollFoot)   payrollFoot.textContent   = 'IDR ' + fmtIdrStr(flooredTotal);
      if (payrollBanner) payrollBanner.textContent = 'IDR ' + fmtIdrStr(flooredTotal);

      const net = incomeIdr - flooredTotal - expensesIdr;
      const netStr = (net < 0 ? '−' : '') + 'IDR ' + fmtIdrStr(Math.abs(net));
      if (netHero)   netHero.textContent   = netStr;
      if (netBanner) netBanner.textContent = netStr;
      applyNetClasses(net);
    }

    document.querySelectorAll('.js-payout-form').forEach(form => {
      const staffId = form.dataset.staff;
      const rate    = parseFloat(form.dataset.rate)     || 0;
      const monthly = parseFloat(form.dataset.monthly)  || 0;
      const cb      = parseFloat(form.dataset.cashback) || 0;
      const type    = form.dataset.type;

      const amountEl   = document.querySelector('.js-amount[data-staff="' + staffId + '"]');
      const lunchEl    = document.querySelector('.js-lunch-display[data-staff="' + staffId + '"]');
      const hoursInput = document.querySelector('.js-hours[data-staff="' + staffId + '"]');
      const daysInput  = document.querySelector('.js-days[data-staff="' + staffId + '"]');

      function recalc() {
        const h = parseFloat(hoursInput?.value) || 0;
        const d = parseInt(daysInput?.value, 10) || 0;
        const lunch = d * cb;
        const base  = (type === 'fixed') ? monthly : (h * rate);
        const total = base + lunch;
        if (amountEl) {
          amountEl.textContent = 'IDR ' + fmtIdrStr(total);
          amountEl.dataset.amount = floorIdr(total);
        }
        if (lunchEl && cb > 0) lunchEl.textContent = 'IDR ' + fmtIdrStr(lunch);
        recalcTotals();
      }
      hoursInput?.addEventListener('input', recalc);
      daysInput?.addEventListener('input', recalc);
    });

    // Initial sum on load — covers the case where some rows have unsaved DB values
    // but we want the visible amount to match data-amount.
    recalcTotals();

    // Save All — fires off all forms in parallel via fetch, then reloads.
    document.getElementById('js-save-all')?.addEventListener('click', async () => {
      const btn = document.getElementById('js-save-all');
      const label = document.querySelector('.js-save-all-label');
      btn.disabled = true; if (label) label.textContent = 'Saving…';
      const forms = [...document.querySelectorAll('.js-payout-form')];
      try {
        await Promise.all(forms.map(f => fetch(f.action, {
          method: 'POST',
          body: new FormData(f),
          headers: { 'Accept': 'text/html' },
          redirect: 'manual',
        })));
        if (label) label.textContent = 'Saved ✓';
        setTimeout(() => window.location.reload(), 400);
      } catch (e) {
        if (label) label.textContent = 'Save failed';
        btn.disabled = false;
      }
    });
  </script>
</div>
