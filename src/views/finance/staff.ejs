<%
  const fmtIDR = n => (n == null || n === '') ? '—' : (Math.floor(Math.max(0, parseFloat(n)) / 100) * 100).toLocaleString('id-ID');
  const active   = staff.filter(s => s.is_active);
  const inactive = staff.filter(s => !s.is_active);
%>

<div class="max-w-5xl">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-5">
    <div class="flex items-center gap-3 min-w-0">
      <a href="/finance/<%= studio.id %>" class="text-slate-400 hover:text-slate-700 shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      </a>
      <div>
        <h1 class="text-xl sm:text-2xl font-bold text-slate-900 tracking-tight"><%= studio.name %> · Karyawan</h1>
        <p class="text-slate-500 text-sm mt-1"><%= active.length %> aktif · <%= inactive.length %> nonaktif · semua nominal dalam IDR</p>
      </div>
    </div>
  </div>

  <!-- Form tambah karyawan -->
  <details class="mb-5 group bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70">
    <summary class="cursor-pointer list-none [&::-webkit-details-marker]:hidden px-4 sm:px-5 py-3 flex items-center justify-between hover:bg-slate-50/40 rounded-xl">
      <span class="text-[11px] font-semibold text-slate-700 uppercase tracking-wider flex items-center gap-2">
        <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        Tambah Karyawan
      </span>
    </summary>
    <div class="border-t border-slate-100 p-4 sm:p-5">
      <form method="POST" action="/finance/<%= studio.id %>/staff" class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div class="sm:col-span-2 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Nama</label>
            <input type="text" name="name" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 outline-none">
          </div>
          <div>
            <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Jabatan / Posisi <span class="text-slate-400 font-normal normal-case tracking-normal">(opsional)</span></label>
            <input type="text" name="role_title" placeholder="mis. Editor, Produser" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 outline-none">
          </div>
        </div>

        <div>
          <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Tipe Gaji</label>
          <select name="salary_type" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 outline-none js-salary-type" data-form="add">
            <option value="hourly">Per Jam</option>
            <option value="fixed">Bulanan Tetap</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Uang Makan / hari (IDR) <span class="text-slate-400 font-normal normal-case tracking-normal">(opsional)</span></label>
          <input type="number" name="lunch_cashback_per_day_idr" step="500" min="0" placeholder="mis. 25000" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm tabular-nums focus:ring-2 focus:ring-slate-900 outline-none">
        </div>
        <div class="js-hourly-fields-add">
          <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Tarif Per Jam (IDR / jam)</label>
          <input type="number" name="hourly_rate_idr" step="500" min="0" placeholder="mis. 30000" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm tabular-nums focus:ring-2 focus:ring-slate-900 outline-none">
        </div>
        <div class="js-fixed-fields-add hidden">
          <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Gaji Bulanan (IDR)</label>
          <input type="number" name="monthly_salary_idr" step="100000" min="0" placeholder="mis. 5000000" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm tabular-nums focus:ring-2 focus:ring-slate-900 outline-none">
        </div>

        <div class="sm:col-span-2">
          <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Tunjangan / bulan (IDR) <span class="text-slate-400 font-normal normal-case tracking-normal">(opsional · transport, kesehatan, dll)</span></label>
          <input type="number" name="tunjangan_idr" step="50000" min="0" placeholder="mis. 500000" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm tabular-nums focus:ring-2 focus:ring-slate-900 outline-none">
        </div>

        <div class="sm:col-span-2">
          <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Catatan <span class="text-slate-400 font-normal normal-case tracking-normal">(opsional)</span></label>
          <input type="text" name="notes" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 outline-none">
        </div>

        <div class="sm:col-span-2 flex justify-end">
          <button type="submit" class="px-4 py-2 bg-slate-900 hover:bg-slate-800 text-white text-[11px] font-semibold tracking-wide uppercase rounded-lg shadow-sm">Tambah Karyawan</button>
        </div>
      </form>
    </div>
  </details>

  <!-- Daftar karyawan -->
  <% if (!staff.length) { %>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-10 text-center text-slate-400 text-sm">
      Belum ada karyawan. Gunakan tombol "Tambah Karyawan" di atas untuk mulai.
    </div>
  <% } %>

  <% [{ label: 'Aktif', list: active }, { label: 'Nonaktif', list: inactive }].forEach(group => { if (!group.list.length) return; %>
    <div class="mb-5">
      <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider mb-2 px-1"><%= group.label %> · <%= group.list.length %></p>
      <div class="space-y-2">
        <% group.list.forEach(s => { %>
          <details class="group bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 <%= s.is_active ? '' : 'opacity-70' %>">
            <summary class="cursor-pointer list-none [&::-webkit-details-marker]:hidden px-4 sm:px-5 py-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 hover:bg-slate-50/40 rounded-xl">
              <div class="flex items-center gap-3 min-w-0 flex-1">
                <svg class="w-3.5 h-3.5 text-slate-400 transition-transform group-open:rotate-90 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                <div class="min-w-0">
                  <p class="text-[15px] font-semibold text-slate-900 tracking-tight truncate">
                    <%= s.name %>
                    <% if (s.role_title) { %><span class="text-[11px] font-normal text-slate-500"> · <%= s.role_title %></span><% } %>
                  </p>
                  <p class="text-[11px] text-slate-500 truncate mt-0.5">
                    <% if (s.salary_type === 'hourly') { %>
                      Per Jam · <span class="tabular-nums">IDR <%= fmtIDR(s.hourly_rate_idr) %></span>/jam
                    <% } else { %>
                      Bulanan · <span class="tabular-nums">IDR <%= fmtIDR(s.monthly_salary_idr) %></span>/bulan
                    <% } %>
                    <% if (s.lunch_cashback_per_day_idr) { %>
                      · uang makan <span class="tabular-nums">IDR <%= fmtIDR(s.lunch_cashback_per_day_idr) %></span>/hari
                    <% } %>
                    <% if (s.tunjangan_idr) { %>
                      · tunjangan <span class="tabular-nums">IDR <%= fmtIDR(s.tunjangan_idr) %></span>/bulan
                    <% } %>
                  </p>
                </div>
              </div>
              <div class="flex gap-1 shrink-0">
                <% if (s.is_active) { %>
                  <span class="px-1.5 py-0.5 rounded-md text-[9.5px] font-semibold tracking-wide bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200/70">AKTIF</span>
                <% } else { %>
                  <span class="px-1.5 py-0.5 rounded-md text-[9.5px] font-semibold tracking-wide bg-slate-100 text-slate-500 ring-1 ring-slate-200/70">NONAKTIF</span>
                <% } %>
              </div>
            </summary>

            <div class="border-t border-slate-100 p-4 sm:p-5">
              <form method="POST" action="/finance/<%= studio.id %>/staff/<%= s.id %>" class="grid grid-cols-1 sm:grid-cols-2 gap-3 js-staff-form" data-form="<%= s.id %>">
                <div>
                  <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Nama</label>
                  <input type="text" name="name" value="<%= s.name %>" required class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 outline-none">
                </div>
                <div>
                  <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Jabatan / Posisi</label>
                  <input type="text" name="role_title" value="<%= s.role_title || '' %>" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 outline-none">
                </div>

                <div>
                  <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Tipe Gaji</label>
                  <select name="salary_type" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 outline-none js-salary-type" data-form="<%= s.id %>">
                    <option value="hourly" <%= s.salary_type === 'hourly' ? 'selected' : '' %>>Per Jam</option>
                    <option value="fixed"  <%= s.salary_type === 'fixed'  ? 'selected' : '' %>>Bulanan Tetap</option>
                  </select>
                </div>
                <div>
                  <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Uang Makan / hari (IDR)</label>
                  <input type="number" name="lunch_cashback_per_day_idr" step="500" min="0" value="<%= s.lunch_cashback_per_day_idr || '' %>" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm tabular-nums focus:ring-2 focus:ring-slate-900 outline-none">
                </div>

                <div class="js-hourly-fields-<%= s.id %> <%= s.salary_type === 'fixed' ? 'hidden' : '' %>">
                  <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Tarif Per Jam (IDR / jam)</label>
                  <input type="number" name="hourly_rate_idr" step="500" min="0" value="<%= s.hourly_rate_idr || '' %>" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm tabular-nums focus:ring-2 focus:ring-slate-900 outline-none">
                </div>
                <div class="js-fixed-fields-<%= s.id %> <%= s.salary_type === 'hourly' ? 'hidden' : '' %>">
                  <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Gaji Bulanan (IDR)</label>
                  <input type="number" name="monthly_salary_idr" step="100000" min="0" value="<%= s.monthly_salary_idr || '' %>" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm tabular-nums focus:ring-2 focus:ring-slate-900 outline-none">
                </div>

                <div class="sm:col-span-2">
                  <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Tunjangan / bulan (IDR) <span class="text-slate-400 font-normal normal-case tracking-normal">(opsional)</span></label>
                  <input type="number" name="tunjangan_idr" step="50000" min="0" value="<%= s.tunjangan_idr || '' %>" placeholder="mis. 500000" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm tabular-nums focus:ring-2 focus:ring-slate-900 outline-none">
                </div>

                <div class="sm:col-span-2">
                  <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Catatan</label>
                  <input type="text" name="notes" value="<%= s.notes || '' %>" class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 outline-none">
                </div>

                <div class="sm:col-span-2 flex items-center justify-between gap-2">
                  <label class="flex items-center gap-2 text-[12px] text-slate-700">
                    <input type="checkbox" name="is_active" value="1" <%= s.is_active ? 'checked' : '' %> class="rounded border-slate-300 text-slate-900 focus:ring-slate-900">
                    Aktif
                  </label>
                  <div class="flex gap-2">
                    <button type="submit" class="px-4 py-2 bg-slate-900 hover:bg-slate-800 text-white text-[11px] font-semibold tracking-wide uppercase rounded-lg shadow-sm">Simpan</button>
                  </div>
                </div>
              </form>

              <% if (s.is_active) { %>
                <form method="POST" action="/finance/<%= studio.id %>/staff/<%= s.id %>/delete" class="mt-3 border-t border-slate-100 pt-3" onsubmit="return confirm('Nonaktifkan <%= s.name %>? Riwayat gaji tetap tersimpan.')">
                  <button type="submit" class="text-[11px] text-rose-600 hover:text-rose-700 font-semibold tracking-wide uppercase">Nonaktifkan</button>
                </form>
              <% } %>
            </div>
          </details>
        <% }) %>
      </div>
    </div>
  <% }) %>

  <script>
    // Toggle visibilitas input per jam vs bulanan untuk setiap form
    document.querySelectorAll('.js-salary-type').forEach(sel => {
      const formKey = sel.dataset.form;
      const hourlyEl = document.querySelector('.js-hourly-fields-' + formKey);
      const fixedEl  = document.querySelector('.js-fixed-fields-'  + formKey);
      sel.addEventListener('change', () => {
        if (sel.value === 'hourly') {
          hourlyEl?.classList.remove('hidden');
          fixedEl?.classList.add('hidden');
        } else {
          hourlyEl?.classList.add('hidden');
          fixedEl?.classList.remove('hidden');
        }
      });
    });
  </script>
</div>
