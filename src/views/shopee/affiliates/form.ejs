<div class="max-w-xl">
  <h1 class="text-2xl font-bold text-gray-800 mb-6"><%= editing ? 'Edit' : 'Add' %> Affiliate</h1>

  <% if (typeof extractResult !== 'undefined' && extractResult) { %>
    <div class="bg-orange-50 border border-orange-200 rounded-xl p-4 mb-6">
      <p class="text-sm font-semibold text-orange-700 mb-2">📄 Extracted from Bank Statement</p>
      <div class="text-xs text-gray-600 space-y-1">
        <p><strong>Bank:</strong> <%= extractResult.bank_name || 'Not detected' %></p>
        <p><strong>Account:</strong> <%= extractResult.account_number || 'Not detected' %></p>
        <p><strong>Holder:</strong> <%= extractResult.account_holder || 'Not detected' %></p>
      </div>
      <p class="text-xs text-orange-500 mt-2">Please review and correct the pre-filled fields below before saving.</p>
    </div>
  <% } %>
  <form method="POST" action="<%= editing ? `/shopee/affiliates/${data.id}/edit` : '/shopee/affiliates/create' %>"
    class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-5">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
      <input type="text" name="full_name" value="<%= data.full_name || '' %>" required
        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm"
        placeholder="NUR HASMANIZA BINTI ZAINAL">
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Bank Name</label>
        <input type="text" name="bank_name" value="<%= data.bank_name || '' %>" required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm"
          placeholder="Maybank">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Account Number</label>
        <input type="text" name="account_number" value="<%= data.account_number || '' %>" required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm font-mono">
      </div>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Phone (optional)</label>
      <input type="text" name="phone" value="<%= data.phone || '' %>"
        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Notes (optional)</label>
      <textarea name="notes" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm"><%= data.notes || '' %></textarea>
    </div>
    <% if (isStudio) { %>
      <input type="hidden" name="studio_id" value="<%= studioId %>">
      <p class="text-xs text-gray-400">This affiliate will be added to your studio.</p>
    <% } else if (typeof studios !== 'undefined') { %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Studio</label>
      <select name="studio_id" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm bg-white">
        <option value="">— No Studio —</option>
        <% studios.forEach(s => { %>
          <option value="<%= s.id %>" <%= (data.studio_id == s.id) ? 'selected' : '' %>><%= s.name %></option>
        <% }) %>
      </select>
    </div>
    <% } %>
    <% if (editing) { %>
    <div class="flex items-center gap-2">
      <input type="checkbox" name="is_active" value="1" id="is_active" <%= data.is_active ? 'checked' : '' %>
        class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
      <label for="is_active" class="text-sm text-gray-700">Active</label>
    </div>
    <% } %>
    <div class="flex gap-3 pt-2">
      <button type="submit" class="px-5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-lg text-sm transition-colors">
        <%= editing ? 'Update' : 'Add' %> Affiliate
      </button>
      <a href="/shopee/affiliates" class="px-5 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-lg text-sm transition-colors">Cancel</a>
    </div>
  </form>
</div>
