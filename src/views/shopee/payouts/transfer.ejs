<%
  const genPct = deductions.general;
  const myPct  = deductions.myAdmin;
  const hqPct  = deductions.myHQ || 0;
%>
<div class="max-w-5xl">
  <div class="flex items-center gap-3 mb-6">
    <a href="/shopee/payouts" class="text-gray-400 hover:text-gray-600">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-gray-800">Bulk Transfer</h1>
      <p class="text-gray-500 text-sm">Select collected payouts and transfer in one batch</p>
    </div>
  </div>

  <!-- Date Filter -->
  <form method="GET" action="/shopee/payouts/transfer" class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 sm:p-5 mb-6">
    <div class="flex flex-col sm:flex-row sm:items-end gap-3 sm:gap-4">
      <div class="flex-1">
        <label class="block text-xs font-medium text-gray-600 mb-1">From</label>
        <input type="date" name="from" value="<%= query.from || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
      </div>
      <div class="flex-1">
        <label class="block text-xs font-medium text-gray-600 mb-1">To</label>
        <input type="date" name="to" value="<%= query.to || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-indigo-500 outline-none">
      </div>
      <div class="flex gap-2">
        <button type="submit" class="flex-1 sm:flex-none px-5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-lg text-sm transition-colors">Filter</button>
        <% if (query.from || query.to) { %>
          <a href="/shopee/payouts/transfer" class="px-4 py-2 text-gray-500 hover:text-gray-700 text-sm">Clear</a>
        <% } %>
      </div>
    </div>
  </form>

  <% if (entries.length === 0) { %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-8 text-center">
      <p class="text-gray-400">No collected payouts found<%= (query.from || query.to) ? ' for this date range' : '' %>.</p>
    </div>
  <% } else { %>
    <form method="POST" action="/shopee/payouts/transfer" enctype="multipart/form-data" id="bulkTransferForm">
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-6">
        <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-gray-50 border-b border-gray-200">
            <tr>
              <th class="px-4 py-3 text-left">
                <input type="checkbox" id="selectAll" class="rounded">
              </th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Account Holder</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Bank</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Account No.</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Invoice</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Date</th>
              <th class="text-right px-4 py-3 font-semibold text-gray-600">Amount (MYR)</th>
              <th class="text-right px-4 py-3 font-semibold text-gray-600">Transfer (MYR)</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% let grandTotal = 0; let grandTransfer = 0; %>
            <% entries.forEach(e => {
              const eAmt = parseFloat(e.payout_amount);
              // All deductions are slices of GROSS (matches manual report).
              const eNet = eAmt * (1 - 0.01 - 0.01 * 0.08);  // physical receive at bank
              const myFee = eAmt * myPct / 100;
              const hqFee = eAmt * hqPct / 100;
              // Expected transfer to ID (manual convention) =
              //   gross × (100% − Shopee% − SST% − general% − myAdmin% − myHQ%)
              const eExpectedTransfer = eAmt * (100 - 1 - 0.08 - genPct - myPct - hqPct) / 100;
              const actualCollected = e.actual_collected_myr != null
                ? parseFloat(e.actual_collected_myr) : null;
              // What flows to ID = actual collected − MY/HQ cut − Shopee fees absorbed.
              const shopeeAbsorbed = eAmt * 1.08 / 100;
              const eTransfer = actualCollected != null
                ? actualCollected - myFee - hqFee - shopeeAbsorbed
                : eExpectedTransfer;
              const usingActual = actualCollected != null;
              grandTotal += eAmt;
              grandTransfer += eTransfer;
            %>
              <tr class="hover:bg-gray-50 transition-colors entry-row">
                <td class="px-4 py-3">
                  <input type="checkbox" name="entry_ids" value="<%= e.id %>"
                         class="entry-check rounded"
                         data-amt="<%= eAmt %>" data-transfer="<%= eTransfer %>">
                </td>
                <td class="px-4 py-3 font-medium text-gray-800"><%= e.affiliate_name || e.extracted_name %></td>
                <td class="px-4 py-3 text-gray-600 text-xs"><%= e.bank_name || '—' %></td>
                <td class="px-4 py-3 text-gray-600 font-mono text-xs"><%= e.account_number || '—' %></td>
                <td class="px-4 py-3 text-gray-600 font-mono text-xs"><%= e.invoice_number || '-' %></td>
                <td class="px-4 py-3 text-gray-600"><%= e.invoice_date ? new Date(e.invoice_date).toLocaleDateString('en-GB') : '-' %></td>
                <td class="px-4 py-3 text-right">
                  <span class="font-semibold text-gray-800"><%= eAmt.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
                  <span class="text-xs text-gray-300 block">~IDR <%= Math.round(eAmt * rate).toLocaleString('id-ID') %></span>
                  <span class="text-[10px] text-gray-400 block">Net after Shopee: <%= eNet.toFixed(2) %></span>
                </td>
                <td class="px-4 py-3 text-right">
                  <span class="font-semibold text-indigo-700"><%= eTransfer.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
                  <span class="text-xs text-indigo-400 block">~IDR <%= Math.round(eTransfer * rate).toLocaleString('id-ID') %></span>
                  <% if (usingActual) { %>
                    <span class="text-[10px] text-emerald-600 block">✓ uses actual collected</span>
                  <% } else { %>
                    <span class="text-[10px] text-gray-400 block">−<%= (genPct + myPct + hqPct).toFixed(1) %>% (expected)</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
          <tfoot class="bg-gray-50 border-t border-gray-200">
            <tr>
              <td colspan="6" class="px-4 py-3 font-semibold text-gray-700">Total (<span id="selectedCount">0</span> selected)</td>
              <td class="px-4 py-3 text-right" data-rate="<%= rate %>">
                <span class="font-bold text-gray-800" id="totalAmount">0.00</span>
                <span class="text-xs text-gray-400 block">~IDR <span id="totalAmountIdr">0</span></span>
              </td>
              <td class="px-4 py-3 text-right">
                <span class="font-bold text-indigo-700" id="totalTransfer">0.00</span>
                <span class="text-xs text-indigo-400 block">~IDR <span id="totalTransferIdr">0</span></span>
              </td>
            </tr>
          </tfoot>
        </table>
        </div>
      </div>

      <!-- Upload proof + submit -->
      <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5">
        <p class="text-sm font-semibold text-gray-700 mb-3">Transfer Proof</p>
        <div class="space-y-3">
          <div>
            <label class="block text-sm text-gray-600 mb-1">Upload transfer proof (screenshot/receipt)</label>
            <input type="file" name="proof" accept="image/*,.pdf" required
              class="w-full text-sm file:mr-3 file:py-1.5 file:px-4 file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 file:rounded-lg file:cursor-pointer">
          </div>
          <button type="submit" class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-lg text-sm transition-colors"
            onclick="return confirm('Transfer selected payouts? This will mark them as transferring.')">
            Mark Selected as Transferring
          </button>
        </div>
      </div>
    </form>

    <script>
      (function() {
        const rate = parseFloat(document.querySelector('[data-rate]').dataset.rate) || 1;
        const checks = document.querySelectorAll('.entry-check');
        const elCount = document.getElementById('selectedCount');
        const elAmount = document.getElementById('totalAmount');
        const elAmountIdr = document.getElementById('totalAmountIdr');
        const elTransfer = document.getElementById('totalTransfer');
        const elTransferIdr = document.getElementById('totalTransferIdr');
        const fmt = n => n.toLocaleString('en-MY', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        const fmtIdr = n => Math.round(n).toLocaleString('id-ID');

        function recalc() {
          let count = 0, amt = 0, xfr = 0;
          checks.forEach(cb => {
            if (cb.checked) {
              count++;
              amt += parseFloat(cb.dataset.amt) || 0;
              xfr += parseFloat(cb.dataset.transfer) || 0;
            }
          });
          elCount.textContent = count;
          elAmount.textContent = fmt(amt);
          elAmountIdr.textContent = fmtIdr(amt * rate);
          elTransfer.textContent = fmt(xfr);
          elTransferIdr.textContent = fmtIdr(xfr * rate);
        }

        document.getElementById('selectAll').addEventListener('change', function() {
          checks.forEach(cb => cb.checked = this.checked);
          recalc();
        });
        checks.forEach(cb => cb.addEventListener('change', recalc));

        // If user arrived with a date filter (came from a period shortcut),
        // pre-check every visible row so they only need to attach proof + submit.
        const params = new URLSearchParams(window.location.search);
        if ((params.get('from') || params.get('to')) && checks.length > 0) {
          checks.forEach(cb => cb.checked = true);
          document.getElementById('selectAll').checked = true;
        }
        recalc();
      })();
    </script>
  <% } %>
</div>
