<div class="max-w-3xl">
  <div class="flex items-center gap-3 mb-6">
    <a href="/shopee/payouts" class="text-gray-400 hover:text-gray-600">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <div>
      <h1 class="text-xl sm:text-2xl font-bold text-gray-800">Payout Detail</h1>
      <p class="text-gray-500 text-sm"><%= entry.affiliate_name || entry.extracted_name %></p>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-6">
    <div class="p-5 space-y-4">
      <!-- Account Holder -->
      <div class="flex justify-between items-start">
        <div>
          <p class="text-xs font-medium text-gray-500">Account Holder</p>
          <p class="text-lg font-bold text-gray-800"><%= entry.affiliate_name || entry.extracted_name %></p>
          <% if (entry.extracted_name && entry.affiliate_name && entry.extracted_name !== entry.affiliate_name) { %>
            <p class="text-xs text-gray-400">Extracted as: <%= entry.extracted_name %></p>
          <% } %>
        </div>
        <div>
          <% if (entry.affiliate_name) { %>
            <span class="px-2.5 py-1 bg-emerald-100 text-emerald-700 rounded-full text-xs font-medium" title="Linked to an affiliate account on file">✓ Linked</span>
          <% } else { %>
            <span class="px-2.5 py-1 bg-amber-100 text-amber-700 rounded-full text-xs font-medium" title="Manual entry — no affiliate account on file">Unlinked</span>
          <% } %>
        </div>
      </div>

      <% if (entry.bank_name || entry.account_number) { %>
        <div class="bg-gray-50 rounded-lg p-3">
          <p class="text-xs font-medium text-gray-500 mb-1">Bank Details</p>
          <p class="text-sm text-gray-800"><%= entry.bank_name %> — <%= entry.account_number %></p>
        </div>
      <% } %>

      <% if (entry.studio_name) { %>
        <p class="text-xs text-gray-500">Studio: <span class="font-medium text-gray-800"><%= entry.studio_name %></span></p>
      <% } %>

      <div class="grid grid-cols-3 gap-4">
        <div>
          <p class="text-xs font-medium text-gray-500">Invoice Number</p>
          <p class="text-sm font-semibold text-gray-800 font-mono"><%= entry.invoice_number || '-' %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-gray-500">Invoice Date</p>
          <p class="text-sm font-semibold text-gray-800"><%= entry.invoice_date ? new Date(entry.invoice_date).toLocaleDateString('en-GB') : '-' %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-gray-500">Period</p>
          <p class="text-sm font-semibold text-gray-800"><%= entry.period_description || '-' %></p>
        </div>
      </div>

      <div class="border-t border-gray-200 pt-4">
        <%
          const amt = parseFloat(entry.payout_amount);
          const shopeeServiceFee = amt * 0.01;
          const shopeeSSTFee = shopeeServiceFee * 0.08;
          const netAfterShopee = amt - shopeeServiceFee - shopeeSSTFee;
          // All deductions are slices of GROSS (matches manual report).
          const genDed = amt * deductions.general / 100;
          const myDed  = amt * deductions.myAdmin / 100;
          const hqDed  = amt * (deductions.myHQ || 0) / 100;
          const idDed  = amt * deductions.idAdmin / 100;
          // afterMyAdmin = what flows from MY admin to ID admin (manual convention).
          //   = needToPay − myAdmin − myHQ − Shopee fees absorbed
          //   ≡ gross × (100% − general% − myAdmin% − myHQ% − 1.08%) / 100
          const needToPay    = amt - genDed;
          const afterMyAdmin = needToPay - myDed - hqDed - shopeeServiceFee - shopeeSSTFee;
          const studioNet    = afterMyAdmin - idDed;
        %>

        <!-- Invoice Amount -->
        <div class="grid grid-cols-2 gap-4 mb-4">
          <div>
            <p class="text-xs font-medium text-gray-500">Invoice Amount (MYR)</p>
            <p class="text-xl sm:text-2xl font-bold text-gray-800"><%= amt.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></p>
            <p class="text-xs text-gray-400">~IDR <%= (Math.floor(Math.max(0, amt * rate) / 100) * 100).toLocaleString('id-ID') %></p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-500">Tax (MYR)</p>
            <p class="text-xl sm:text-2xl font-bold text-gray-500"><%= parseFloat(entry.tax_amount || 0).toFixed(2) %></p>
          </div>
        </div>

        <!-- Shopee Fees (hidden for studio role — they only need to see the gross invoice and what they actually received) -->
        <% if (user.role !== 'studio') { %>
          <div class="bg-orange-50 rounded-lg p-3 mb-4 space-y-1">
            <p class="text-xs font-semibold text-orange-700 mb-1">Shopee Platform Fees</p>
            <div class="flex justify-between text-xs">
              <span class="text-gray-500">Service Fee (1%)</span>
              <span class="text-red-500">-<%= shopeeServiceFee.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
            <div class="flex justify-between text-xs">
              <span class="text-gray-500">SST on Service Fee (8%)</span>
              <span class="text-red-500">-<%= shopeeSSTFee.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
            <div class="flex justify-between text-xs border-t border-orange-200 pt-1">
              <span class="font-medium text-gray-700">Net after Shopee fees</span>
              <span class="font-bold text-gray-800"><%= netAfterShopee.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
          </div>
        <% } %>

        <% if (user.role === 'superadmin') { %>
          <!-- Superadmin: full breakdown -->
          <div class="bg-gray-50 rounded-lg p-4 space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">MY Admin (<%= deductions.myAdmin %>%)</span>
              <span class="text-red-500">-<%= myDed.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">MY HQ (<%= deductions.myHQ || 0 %>%)</span>
              <span class="text-red-500">-<%= hqDed.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">Bank Holder (<%= deductions.general %>%)</span>
              <span class="text-red-500">-<%= genDed.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
            <div class="flex justify-between text-sm border-t pt-2">
              <span class="font-medium text-gray-700">Transfer to Indonesia</span>
              <span class="font-bold text-indigo-700"><%= afterMyAdmin.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">ID Admin (<%= deductions.idAdmin %>%)</span>
              <span class="text-red-500">-<%= idDed.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
            <div class="flex justify-between text-sm border-t pt-2">
              <span class="font-bold text-gray-700">Studio receives</span>
              <span class="font-bold text-emerald-700"><%= studioNet.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
          </div>

        <% } else if (user.role === 'malaysia_admin') { %>
          <!-- MY Admin: their cut + HQ + bank holder share + transfer amount -->
          <div class="bg-gray-50 rounded-lg p-4 space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">MY Admin (<%= deductions.myAdmin %>%)</span>
              <span class="text-red-500">-<%= myDed.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">MY HQ (<%= deductions.myHQ || 0 %>%)</span>
              <span class="text-red-500">-<%= hqDed.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">Bank Holder (<%= deductions.general %>%)</span>
              <span class="text-red-500">-<%= genDed.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
            <div class="flex justify-between text-sm border-t pt-2">
              <span class="font-bold text-gray-700">Transfer to Indonesia</span>
              <span class="font-bold text-indigo-700"><%= afterMyAdmin.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
          </div>

        <% } else if (user.role === 'indonesia_admin') { %>
          <!-- ID Admin: sees received amount and their earnings (no percentage shown) -->
          <div class="bg-gray-50 rounded-lg p-4 space-y-2">
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">Received from Malaysia</span>
              <span class="font-medium text-gray-800"><%= afterMyAdmin.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
            <div class="flex justify-between text-sm">
              <span class="text-gray-500">Your earnings</span>
              <span class="font-bold text-emerald-700"><%= idDed.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
            <div class="flex justify-between text-sm border-t pt-2">
              <span class="font-bold text-gray-700">Send to studio</span>
              <span class="font-bold text-indigo-700"><%= studioNet.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
            </div>
          </div>

        <% } %>

        <% if (user.role !== 'studio') { %>
          <p class="text-xs text-gray-400 mt-2">Rate: 1 MYR ≈ <%= rate.toLocaleString() %> IDR · Estimated<% if (rateMeta && rateMeta.updated_at) { %> · updated <%= relativeTime(rateMeta.updated_at) %><% } %></p>
        <% } %>

        <% if (entry.actual_collected_myr != null || entry.actual_distributed_idr != null) { %>
          <div class="mt-4 bg-emerald-50 border border-emerald-200 rounded-lg p-4 space-y-2 text-sm">
            <p class="text-xs font-semibold text-emerald-700 uppercase tracking-wide">Actual amounts</p>
            <% if (entry.actual_collected_myr != null) {
                 const expected = needToPay;
                 const actual = parseFloat(entry.actual_collected_myr);
                 const delta = actual - expected;
            %>
              <div class="flex justify-between">
                <span class="text-gray-600">Collected from bank holder</span>
                <span class="font-semibold text-gray-800">MYR <%= actual.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
              </div>
              <% if (Math.abs(delta) > 0.01) { %>
                <div class="flex justify-between text-xs">
                  <span class="text-gray-500">vs expected MYR <%= expected.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
                  <span class="<%= delta < 0 ? 'text-red-600' : 'text-emerald-600' %> font-medium">Δ <%= delta > 0 ? '+' : '' %><%= delta.toFixed(2) %></span>
                </div>
              <% } %>
            <% } %>
            <% if (entry.actual_distributed_idr != null) { %>
              <div class="flex justify-between border-t border-emerald-200 pt-2">
                <span class="text-gray-600">Studio received</span>
                <span class="font-bold text-emerald-700">IDR <%= (Math.floor(Math.max(0, parseFloat(entry.actual_distributed_idr)) / 100) * 100).toLocaleString('id-ID') %></span>
              </div>
              <% if (entry.actual_fx_rate) { %>
                <p class="text-xs text-gray-500">at rate 1 MYR = <%= parseFloat(entry.actual_fx_rate).toLocaleString() %> IDR (actual transfer rate)</p>
              <% } %>
            <% } %>
          </div>
        <% } %>
      </div>

      <div class="border-t border-gray-200 pt-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-medium text-gray-500">Status</p>
            <%
              const colors = {
                processing:'bg-blue-100 text-blue-700',
                collected:'bg-amber-100 text-amber-700',
                transferring:'bg-indigo-100 text-indigo-700',
                received:'bg-purple-100 text-purple-700',
                distributed:'bg-orange-100 text-orange-700',
                completed:'bg-emerald-100 text-emerald-700'
              };
              const role = user.role;
              let nextAction = null;
              if (entry.payment_status === 'processing' && (role === 'malaysia_admin' || role === 'superadmin')) {
                nextAction = { status: 'collected', label: 'Mark Collected', color: 'bg-amber-600 hover:bg-amber-500' };
              } else if (entry.payment_status === 'collected' && (role === 'malaysia_admin' || role === 'superadmin')) {
                nextAction = { status: 'transferring', label: 'Mark Transferring', color: 'bg-indigo-600 hover:bg-indigo-500', needsProof: true };
              } else if (entry.payment_status === 'transferring' && (role === 'indonesia_admin' || role === 'superadmin')) {
                nextAction = { status: 'received', label: 'Mark Received', color: 'bg-purple-600 hover:bg-purple-500' };
              } else if (entry.payment_status === 'received' && (role === 'indonesia_admin' || role === 'superadmin')) {
                nextAction = { status: 'distributed', label: 'Mark Distributed', color: 'bg-orange-600 hover:bg-orange-500', needsProof: true };
              } else if (entry.payment_status === 'distributed' && (role === 'studio' || role === 'superadmin')) {
                nextAction = { status: 'completed', label: 'Confirm Received', color: 'bg-emerald-600 hover:bg-emerald-500' };
              }
            %>
            <span class="inline-block mt-1 px-3 py-1 rounded-full text-sm font-semibold <%= colors[entry.payment_status] %>"><%= entry.payment_status.toUpperCase() %></span>
          </div>
          <div>
            <% if (entry.payment_time) { %>
              <p class="text-xs font-medium text-gray-500">Last Updated</p>
              <p class="text-sm text-gray-800"><%= new Date(entry.payment_time).toLocaleString('en-GB') %></p>
            <% } %>

            <%
              // Determine rollback action
              let rollbackAction = null;
              const prevStatus = {
                collected: 'processing',
                transferring: 'collected',
                received: 'transferring',
                distributed: 'received',
                completed: 'distributed'
              };
              const rollbackAllowed = {
                processing: ['malaysia_admin', 'superadmin'],
                collected: ['malaysia_admin', 'superadmin'],
                transferring: ['indonesia_admin', 'superadmin'],
                received: ['indonesia_admin', 'superadmin'],
                distributed: ['studio', 'superadmin'],
              };
              const prev = prevStatus[entry.payment_status];
              if (prev && rollbackAllowed[prev] && rollbackAllowed[prev].includes(user.role)) {
                rollbackAction = { status: prev, label: '↩ Revert to ' + prev };
              }
            %>
          </div>
        </div>
      </div>

      <% if (isISHAdmin) { %>
        <div class="border-t border-gray-200 pt-4">
          <p class="text-xs font-semibold text-gray-500 mb-2">Audit Trail</p>
          <div class="space-y-1.5 text-xs">
            <div class="flex justify-between">
              <span class="text-gray-500">Created by</span>
              <span class="text-gray-800">
                <%= entry.created_by_name || '—' %>
                <% if (entry.created_at) { %>
                  <span class="text-gray-400">· <%= new Date(entry.created_at).toLocaleString('en-GB') %></span>
                <% } %>
              </span>
            </div>
            <% if (entry.collected_by || entry.collected_by_name) { %>
              <div class="flex justify-between">
                <span class="text-gray-500">Collected by</span>
                <span class="text-gray-800">
                  <%= entry.collected_by_name || '—' %>
                  <% if (entry.payment_time) { %>
                    <span class="text-gray-400">· <%= new Date(entry.payment_time).toLocaleString('en-GB') %></span>
                  <% } %>
                </span>
              </div>
            <% } %>
            <div class="flex justify-between">
              <span class="text-gray-500">Last updated</span>
              <span class="text-gray-800"><%= entry.updated_at ? new Date(entry.updated_at).toLocaleString('en-GB') : '—' %></span>
            </div>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Invoice PDF Preview -->
    <% if (entry.invoice_file_path) { %>
      <div class="border-t border-gray-200 p-5">
        <p class="text-xs font-medium text-gray-500 mb-2">📄 Shopee Invoice PDF</p>
        <div class="bg-gray-50 rounded-lg overflow-hidden" style="height: 500px">
          <iframe src="<%= entry.invoice_file_path %>" width="100%" height="100%" style="border:none;"></iframe>
        </div>
        <a href="<%= entry.invoice_file_path %>" target="_blank" class="inline-block mt-2 text-xs text-indigo-600 hover:underline">Open in new tab ↗</a>
      </div>
    <% } %>

    <!-- Proofs -->
    <% if (entry.transfer_proof_path) { %>
      <div class="border-t border-gray-200 p-5">
        <p class="text-xs font-medium text-gray-500 mb-2">🇲🇾 Transfer Proof (MY → ID)</p>
        <% if (entry.transfer_proof_path.endsWith('.pdf')) { %>
          <iframe src="<%= entry.transfer_proof_path %>" width="100%" height="400" style="border:none;" class="rounded-lg"></iframe>
        <% } else { %>
          <img src="<%= entry.transfer_proof_path %>" alt="Transfer proof" class="max-w-md rounded-lg border border-gray-200">
        <% } %>
        <a href="<%= entry.transfer_proof_path %>" target="_blank" class="inline-block mt-2 text-xs text-indigo-600 hover:underline">Open ↗</a>
      </div>
    <% } %>

    <% if (entry.distribution_proof_path) { %>
      <div class="border-t border-gray-200 p-5">
        <p class="text-xs font-medium text-gray-500 mb-2">🇮🇩 Payment Proof (Admin → Studio)</p>
        <% if (entry.distribution_proof_path.endsWith('.pdf')) { %>
          <iframe src="<%= entry.distribution_proof_path %>" width="100%" height="400" style="border:none;" class="rounded-lg"></iframe>
        <% } else { %>
          <img src="<%= entry.distribution_proof_path %>" alt="Payment proof" class="max-w-md rounded-lg border border-gray-200">
        <% } %>
        <a href="<%= entry.distribution_proof_path %>" target="_blank" class="inline-block mt-2 text-xs text-indigo-600 hover:underline">Open ↗</a>
      </div>
    <% } %>
  </div>

  <!-- Actions -->
  <% if (nextAction || rollbackAction) { %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 mb-6">
      <% if (nextAction) { %>
        <p class="text-sm font-semibold text-gray-700 mb-3"><%= nextAction.label %></p>
        <% if (nextAction.needsProof) { %>
          <form method="POST" action="/shopee/payouts/<%= entry.id %>/status" enctype="multipart/form-data" class="space-y-3">
            <input type="hidden" name="status" value="<%= nextAction.status %>">
            <div>
              <label class="block text-sm text-gray-600 mb-1">
                <%= nextAction.status === 'transferring' ? 'Upload transfer proof (screenshot/receipt)' : 'Upload payment proof (screenshot/receipt)' %>
              </label>
              <input type="file" name="proof" accept="image/*,.pdf" required
                class="w-full text-sm file:mr-3 file:py-1.5 file:px-4 file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 file:rounded-lg file:cursor-pointer">
            </div>
            <button type="submit" class="px-5 py-2 <%= nextAction.color %> text-white font-medium rounded-lg text-sm transition-colors"><%= nextAction.label %></button>
          </form>
        <% } else { %>
          <form method="POST" action="/shopee/payouts/<%= entry.id %>/status" class="inline">
            <input type="hidden" name="status" value="<%= nextAction.status %>">
            <button type="submit" class="px-5 py-2 <%= nextAction.color %> text-white font-medium rounded-lg text-sm transition-colors"><%= nextAction.label %></button>
          </form>
        <% } %>
      <% } %>

      <% if (rollbackAction) { %>
        <form method="POST" action="/shopee/payouts/<%= entry.id %>/status" class="inline mt-3" onsubmit="return confirm('Revert status to <%= rollbackAction.status %>?')">
          <input type="hidden" name="status" value="<%= rollbackAction.status %>">
          <button type="submit" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-600 font-medium rounded-lg text-xs border border-gray-300 transition-colors"><%= rollbackAction.label %></button>
        </form>
      <% } %>
    </div>
  <% } %>

  <div class="flex gap-3 flex-wrap">
    <% if ((isSuperAdmin || isMYAdmin) && entry.payout_period_id) { %>
      <a href="/shopee/payouts/report/<%= entry.payout_period_id %>" target="_blank"
         class="px-5 py-2 bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-medium rounded-lg text-sm border border-indigo-200 transition-colors">
        📄 Download Period Report
      </a>
    <% } %>
    <% if (isISHAdmin) { %>
      <form method="POST" action="/shopee/payouts/<%= entry.id %>/delete" onsubmit="return confirm('Delete this payout entry? This cannot be undone.')">
        <button class="px-5 py-2 bg-red-50 hover:bg-red-100 text-red-600 font-medium rounded-lg text-sm border border-red-200 transition-colors">Delete</button>
      </form>
    <% } %>
    <a href="/shopee/payouts" class="px-5 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-lg text-sm transition-colors">← Back</a>
  </div>
</div>
