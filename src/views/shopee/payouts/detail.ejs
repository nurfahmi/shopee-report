<div class="max-w-3xl">
  <div class="flex items-center gap-3 mb-6">
    <a href="/shopee/payouts" class="text-gray-400 hover:text-gray-600">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <div>
      <h1 class="text-2xl font-bold text-gray-800">Payout Detail</h1>
      <p class="text-gray-500 text-sm"><%= entry.affiliate_name || entry.extracted_name %></p>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-6">
    <div class="p-5 space-y-4">
      <!-- Account Holder -->
      <div class="flex justify-between items-start">
        <div>
          <p class="text-xs font-medium text-gray-500">Account Holder</p>
          <p class="text-lg font-bold text-gray-800"><%= entry.affiliate_name || entry.extracted_name %></p>
          <% if (entry.extracted_name && entry.affiliate_name && entry.extracted_name !== entry.affiliate_name) { %>
            <p class="text-xs text-gray-400">Extracted as: <%= entry.extracted_name %></p>
          <% } %>
        </div>
        <div>
          <% if (entry.affiliate_name) { %>
            <span class="px-2.5 py-1 bg-emerald-100 text-emerald-700 rounded-full text-xs font-medium">✓ Linked</span>
          <% } else { %>
            <span class="px-2.5 py-1 bg-amber-100 text-amber-700 rounded-full text-xs font-medium">Unlinked</span>
          <% } %>
        </div>
      </div>

      <% if (entry.bank_name || entry.account_number) { %>
        <div class="bg-gray-50 rounded-lg p-3">
          <p class="text-xs font-medium text-gray-500 mb-1">Bank Details</p>
          <p class="text-sm text-gray-800"><%= entry.bank_name %> — <%= entry.account_number %></p>
        </div>
      <% } %>

      <div class="grid grid-cols-3 gap-4">
        <div>
          <p class="text-xs font-medium text-gray-500">Invoice Number</p>
          <p class="text-sm font-semibold text-gray-800 font-mono"><%= entry.invoice_number || '-' %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-gray-500">Invoice Date</p>
          <p class="text-sm font-semibold text-gray-800"><%= entry.invoice_date ? new Date(entry.invoice_date).toLocaleDateString('en-GB') : '-' %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-gray-500">Period</p>
          <p class="text-sm font-semibold text-gray-800"><%= entry.period_description || '-' %></p>
        </div>
      </div>

      <div class="border-t border-gray-200 pt-4">
        <div class="grid grid-cols-3 gap-4">
          <div>
            <p class="text-xs font-medium text-gray-500">Net Payable (MYR)</p>
            <p class="text-2xl font-bold text-gray-800"><%= parseFloat(entry.payout_amount).toLocaleString('en-MY',{minimumFractionDigits:2}) %></p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-500">Tax (MYR)</p>
            <p class="text-2xl font-bold text-gray-500"><%= parseFloat(entry.tax_amount || 0).toFixed(2) %></p>
          </div>
          <div>
            <p class="text-xs font-medium text-gray-500">Est. Amount (IDR)</p>
            <p class="text-2xl font-bold text-indigo-600">~<%= parseInt(entry.payout_amount_idr || 0).toLocaleString('id-ID') %></p>
          </div>
        </div>
        <p class="text-xs text-gray-400 mt-1">Rate: 1 MYR = <%= rate.toLocaleString() %> IDR · Estimated — actual may differ due to transfer fees</p>
      </div>

      <div class="border-t border-gray-200 pt-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-xs font-medium text-gray-500">Status</p>
            <% const colors = {pending:'bg-amber-100 text-amber-700',collected:'bg-emerald-100 text-emerald-700',transferred:'bg-blue-100 text-blue-700',confirmed:'bg-gray-100 text-gray-600'}; %>
            <span class="inline-block mt-1 px-3 py-1 rounded-full text-sm font-semibold <%= colors[entry.payment_status] %>"><%= entry.payment_status.toUpperCase() %></span>
          </div>
          <div>
            <% if (entry.payment_time) { %>
              <p class="text-xs font-medium text-gray-500">Collected On</p>
              <p class="text-sm text-gray-800"><%= new Date(entry.payment_time).toLocaleString('en-GB') %></p>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- Invoice PDF Preview -->
    <% if (entry.invoice_file_path) { %>
      <div class="border-t border-gray-200 p-5">
        <p class="text-xs font-medium text-gray-500 mb-2">Shopee Invoice PDF</p>
        <div class="bg-gray-50 rounded-lg overflow-hidden" style="height: 600px">
          <iframe src="<%= entry.invoice_file_path %>" width="100%" height="100%" style="border:none;"></iframe>
        </div>
        <a href="<%= entry.invoice_file_path %>" target="_blank" class="inline-block mt-2 text-xs text-indigo-600 hover:underline">Open in new tab ↗</a>
      </div>
    <% } %>
  </div>

  <!-- Actions -->
  <div class="flex gap-3">
    <% if (entry.payment_status === 'pending') { %>
      <form method="POST" action="/shopee/payouts/<%= entry.id %>/collect">
        <button class="px-5 py-2 bg-emerald-600 hover:bg-emerald-500 text-white font-medium rounded-lg text-sm transition-colors">Mark as Collected</button>
      </form>
    <% } %>
    <% if (isISHAdmin && entry.payment_status === 'pending') { %>
      <form method="POST" action="/shopee/payouts/<%= entry.id %>/delete" onsubmit="return confirm('Delete this payout entry?')">
        <button class="px-5 py-2 bg-red-50 hover:bg-red-100 text-red-600 font-medium rounded-lg text-sm border border-red-200 transition-colors">Delete</button>
      </form>
    <% } %>
    <a href="/shopee/payouts" class="px-5 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-lg text-sm transition-colors">← Back</a>
  </div>
</div>
