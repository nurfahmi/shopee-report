<div class="flex items-center justify-center min-h-[60vh]">
  <div class="text-center">
    <div class="text-6xl font-bold text-gray-200 mb-4">403</div>
    <h1 class="text-xl font-bold text-gray-800 mb-2"><%= typeof title !== 'undefined' ? title : 'Error' %></h1>
    <p class="text-gray-500 mb-6"><%= typeof message !== 'undefined' ? message : 'Something went wrong.' %></p>
    <a href="/dashboard" class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-lg text-sm transition-colors">
      Back to Dashboard
    </a>
  </div>
</div>
