<div class="max-w-xl">
  <h1 class="text-xl sm:text-2xl font-bold text-gray-800 mb-6"><%= editing ? 'Edit' : 'Add' %> Business Profile</h1>

  <form method="POST" action="<%= editing ? `/business-profiles/${data.id}/edit` : '/business-profiles/create' %>"
    enctype="multipart/form-data" class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 space-y-5">

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Business Name</label>
      <input type="text" name="name" value="<%= data.name || '' %>" required
        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Logo</label>
      <% if (editing && data.logo_path) { %>
        <img src="<%= data.logo_path %>" class="w-16 h-16 rounded-lg object-cover mb-2 border border-gray-200" alt="">
      <% } %>
      <input type="file" name="logo" accept="image/*"
        class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm file:mr-3 file:py-1 file:px-3 file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100">
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Address</label>
      <textarea name="address" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm"><%= data.address || '' %></textarea>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
        <input type="email" name="email" value="<%= data.email || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
        <input type="text" name="phone" value="<%= data.phone || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm">
      </div>
    </div>
    <hr class="border-gray-200">
    <p class="text-sm font-semibold text-gray-700">Bank Details (shown on invoice)</p>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Bank Name</label>
      <input type="text" name="bank_name" value="<%= data.bank_name || '' %>"
        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm">
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Account Number</label>
        <input type="text" name="bank_account_number" value="<%= data.bank_account_number || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Account Name</label>
        <input type="text" name="bank_account_name" value="<%= data.bank_account_name || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none text-sm">
      </div>
    </div>
    <div class="flex items-center gap-2">
      <input type="checkbox" name="is_default" value="1" id="is_default" <%= (data.is_default) ? 'checked' : '' %>
        class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
      <label for="is_default" class="text-sm text-gray-700">Set as default profile</label>
    </div>
    <div class="flex gap-3 pt-2">
      <button type="submit" class="px-5 py-2 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-lg text-sm transition-colors">
        <%= editing ? 'Update' : 'Create' %> Profile
      </button>
      <a href="/business-profiles" class="px-5 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-lg text-sm transition-colors">Cancel</a>
    </div>
  </form>
</div>
