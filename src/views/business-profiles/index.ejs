<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-800">Business Profiles</h1>
    <p class="text-gray-500 text-sm mt-1">Manage sender identities for invoices</p>
  </div>
  <a href="/business-profiles/create" class="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white font-medium rounded-lg text-sm transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Add Profile
  </a>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
  <% profiles.forEach(p => { %>
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 relative">
      <% if (p.is_default) { %>
        <span class="absolute top-3 right-3 px-2 py-0.5 bg-indigo-100 text-indigo-700 rounded text-xs font-medium">Default</span>
      <% } %>
      <div class="flex items-start gap-4">
        <% if (p.logo_path) { %>
          <img src="<%= p.logo_path %>" class="w-12 h-12 rounded-lg object-cover border border-gray-200" alt="">
        <% } else { %>
          <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center text-gray-400">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5"/></svg>
          </div>
        <% } %>
        <div class="flex-1">
          <h3 class="font-semibold text-gray-800"><%= p.name %></h3>
          <p class="text-sm text-gray-500 mt-0.5"><%= p.email || 'No email' %></p>
          <p class="text-xs text-gray-400 mt-0.5"><%= p.phone || '' %></p>
          <% if (p.bank_name) { %>
            <p class="text-xs text-gray-400 mt-1"><%= p.bank_name %> — <%= p.bank_account_number %></p>
          <% } %>
        </div>
      </div>
      <div class="flex gap-2 mt-4 border-t border-gray-100 pt-3">
        <a href="/business-profiles/<%= p.id %>/edit" class="text-sm text-indigo-600 hover:text-indigo-500 font-medium">Edit</a>
        <% if (!p.is_default) { %>
          <form method="POST" action="/business-profiles/<%= p.id %>/delete" class="inline" onsubmit="return confirm('Delete this profile?')">
            <button type="submit" class="text-sm text-red-500 hover:text-red-600 font-medium">Delete</button>
          </form>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>
