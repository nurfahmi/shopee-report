<h1 class="text-2xl font-bold text-gray-800">Dashboard</h1>
<p class="text-gray-500 text-sm mt-1">Overview of your business operations</p>

<!-- Stats Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5 mt-6">
  <!-- Payout Stats -->
  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
    <div class="flex items-center justify-between">
      <p class="text-sm font-medium text-gray-500">Total Periods</p>
      <span class="bg-indigo-100 text-indigo-600 p-2 rounded-lg">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      </span>
    </div>
    <p class="text-3xl font-bold text-gray-800 mt-3"><%= stats.payout?.total_periods || 0 %></p>
    <p class="text-xs text-gray-400 mt-1">Shopee payout periods</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
    <div class="flex items-center justify-between">
      <p class="text-sm font-medium text-gray-500">Pending Payouts</p>
      <span class="bg-amber-100 text-amber-600 p-2 rounded-lg">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </span>
    </div>
    <p class="text-3xl font-bold text-gray-800 mt-3"><%= stats.payout?.pending_periods || 0 %></p>
    <p class="text-xs text-gray-400 mt-1">Awaiting settlement</p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
    <div class="flex items-center justify-between">
      <p class="text-sm font-medium text-gray-500">Total Received</p>
      <span class="bg-emerald-100 text-emerald-600 p-2 rounded-lg">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </span>
    </div>
    <p class="text-3xl font-bold text-gray-800 mt-3">MYR <%= (parseFloat(stats.payout?.total_received) || 0).toLocaleString('en-MY', {minimumFractionDigits:2}) %></p>
    <p class="text-xs text-gray-400 mt-1">From completed payouts</p>
  </div>

  <% if (stats.invoice) { %>
  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm">
    <div class="flex items-center justify-between">
      <p class="text-sm font-medium text-gray-500">Outstanding</p>
      <span class="bg-red-100 text-red-600 p-2 rounded-lg">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      </span>
    </div>
    <p class="text-3xl font-bold text-gray-800 mt-3">MYR <%= (parseFloat(stats.invoice?.total_outstanding) || 0).toLocaleString('en-MY', {minimumFractionDigits:2}) %></p>
    <p class="text-xs text-gray-400 mt-1"><%= stats.invoice?.unpaid_count || 0 %> unpaid invoices</p>
  </div>
  <% } %>
</div>

<!-- Recent Payouts -->
<div class="mt-8">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-gray-800">Recent Payout Periods</h2>
    <a href="/shopee/payouts" class="text-sm text-indigo-600 hover:text-indigo-500 font-medium">View all →</a>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-gray-50 border-b border-gray-200">
        <tr>
          <th class="text-left px-5 py-3 font-semibold text-gray-600">Period</th>
          <th class="text-left px-5 py-3 font-semibold text-gray-600">Date</th>
          <th class="text-right px-5 py-3 font-semibold text-gray-600">Gross (MYR)</th>
          <th class="text-right px-5 py-3 font-semibold text-gray-600">Net to ISH</th>
          <th class="text-center px-5 py-3 font-semibold text-gray-600">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% if (recentPayouts.length === 0) { %>
          <tr><td colspan="5" class="px-5 py-8 text-center text-gray-400">No payout periods yet.</td></tr>
        <% } %>
        <% recentPayouts.forEach(p => { %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-5 py-3">
              <a href="/shopee/payouts/<%= p.id %>" class="text-indigo-600 hover:underline font-medium"><%= p.period_label %></a>
              <p class="text-xs text-gray-400"><%= p.period_number %></p>
            </td>
            <td class="px-5 py-3 text-gray-600"><%= p.payout_date ? new Date(p.payout_date).toLocaleDateString('en-GB') : '-' %></td>
            <td class="px-5 py-3 text-right font-medium text-gray-800"><%= parseFloat(p.total_gross || 0).toLocaleString('en-MY', {minimumFractionDigits:2}) %></td>
            <td class="px-5 py-3 text-right font-medium text-emerald-600"><%= parseFloat(p.net_to_ish || 0).toLocaleString('en-MY', {minimumFractionDigits:2}) %></td>
            <td class="px-5 py-3 text-center">
              <% const statusColors = {open:'bg-gray-100 text-gray-600',submitted:'bg-blue-100 text-blue-700',transferring:'bg-amber-100 text-amber-700',pending_confirmation:'bg-purple-100 text-purple-700',complete:'bg-emerald-100 text-emerald-700'}; %>
              <span class="px-2.5 py-1 rounded-full text-xs font-medium <%= statusColors[p.status] || 'bg-gray-100 text-gray-600' %>">
                <%= p.status.replace('_',' ') %>
              </span>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
