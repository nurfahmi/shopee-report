<%
  const s = payoutStats;
  const totalMYR = parseFloat(s.total_myr || 0);
  const shopeeNet = totalMYR * (1 - 0.01 - 0.01 * 0.08);
  const genPct = deductions.general;
  const myPct = deductions.myAdmin;
  const idPct = deductions.idAdmin;
  const afterMyAdmin = shopeeNet * (1 - (genPct + myPct) / 100);
  const idEarnings = shopeeNet * idPct / 100;
  const studioNet = shopeeNet * (1 - (genPct + myPct + idPct) / 100);

  const colors = {
    processing:'bg-blue-100 text-blue-700',
    collected:'bg-amber-100 text-amber-700',
    transferring:'bg-indigo-100 text-indigo-700',
    received:'bg-purple-100 text-purple-700',
    distributed:'bg-orange-100 text-orange-700',
    completed:'bg-emerald-100 text-emerald-700'
  };
%>

<h1 class="text-xl sm:text-2xl font-bold text-gray-800">Dashboard</h1>
<p class="text-gray-500 text-sm mt-1">Welcome back, <%= user.name %>.</p>

<!-- ═══ SUPERADMIN ═══ -->
<% if (user.role === 'superadmin') { %>
<div class="grid grid-cols-2 gap-3 sm:gap-4 mt-6">
  <div class="bg-white rounded-xl border border-gray-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-gray-500">Total Invoices</p>
    <p class="text-2xl sm:text-3xl font-bold text-gray-800 mt-2"><%= parseInt(s.total_entries) %></p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-gray-500">Total (MYR)</p>
    <p class="text-lg sm:text-2xl font-bold text-gray-800 mt-2"><%= totalMYR.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></p>
    <p class="text-xs text-indigo-500 font-medium mt-1">~IDR <%= Math.round(totalMYR * rate).toLocaleString('id-ID') %></p>
    <p class="text-xs text-gray-400">Studio Net: MYR <%= studioNet.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-gray-500">Processing</p>
    <p class="text-2xl sm:text-3xl font-bold text-blue-600 mt-2"><%= parseInt(s.processing_count || 0) %></p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-gray-500">Completed</p>
    <p class="text-2xl sm:text-3xl font-bold text-emerald-600 mt-2"><%= parseInt(s.completed_count || 0) %></p>
  </div>
</div>

<!-- Pipeline progress -->
<div class="grid grid-cols-3 sm:grid-cols-6 gap-2 mt-4">
  <% ['processing','collected','transferring','received','distributed','completed'].forEach(st => { %>
    <div class="bg-white rounded-lg border border-gray-200 p-2 sm:p-3 text-center shadow-sm">
      <p class="text-[10px] sm:text-xs text-gray-500 capitalize truncate"><%= st %></p>
      <p class="text-lg sm:text-xl font-bold text-gray-800 mt-0.5"><%= parseInt(s[st+'_count'] || 0) %></p>
    </div>
  <% }) %>
</div>

<!-- ═══ MALAYSIA ADMIN ═══ -->
<% } else if (user.role === 'malaysia_admin') { %>
<div class="grid grid-cols-2 gap-3 sm:gap-4 mt-6">
  <div class="bg-white rounded-xl border border-blue-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-blue-600">To Collect</p>
    <p class="text-2xl sm:text-3xl font-bold text-blue-700 mt-2"><%= parseInt(s.processing_count || 0) %></p>
    <p class="text-xs text-gray-400 mt-1">Awaiting collection</p>
  </div>
  <div class="bg-white rounded-xl border border-amber-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-amber-600">To Transfer</p>
    <p class="text-2xl sm:text-3xl font-bold text-amber-700 mt-2"><%= parseInt(s.collected_count || 0) %></p>
    <p class="text-xs text-gray-400 mt-1">Needs transfer proof</p>
  </div>
  <div class="bg-white rounded-xl border border-emerald-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-emerald-600">Your Earnings</p>
    <% const myEarnings = shopeeNet * myPct / 100; %>
    <p class="text-lg sm:text-2xl font-bold text-emerald-700 mt-2">MYR <%= myEarnings.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></p>
    <p class="text-xs text-emerald-500 font-medium mt-1">~IDR <%= Math.round(myEarnings * rate).toLocaleString('id-ID') %></p>
  </div>
  <div class="bg-white rounded-xl border border-indigo-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-indigo-600">Transfer Amount</p>
    <p class="text-lg sm:text-2xl font-bold text-indigo-700 mt-2">MYR <%= afterMyAdmin.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></p>
    <p class="text-xs text-indigo-500 font-medium mt-1">~IDR <%= Math.round(afterMyAdmin * rate).toLocaleString('id-ID') %></p>
  </div>
  <div class="col-span-2 bg-white rounded-xl border border-gray-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-gray-500">Transferred</p>
    <p class="text-2xl sm:text-3xl font-bold text-emerald-600 mt-2"><%= parseInt(s.transferring_count || 0) + parseInt(s.received_count || 0) + parseInt(s.distributed_count || 0) + parseInt(s.completed_count || 0) %></p>
    <p class="text-xs text-gray-400 mt-1">Already sent to Indonesia</p>
  </div>
</div>

<!-- ═══ INDONESIA ADMIN ═══ -->
<% } else if (user.role === 'indonesia_admin') { %>
<div class="grid grid-cols-2 gap-3 sm:gap-4 mt-6">
  <div class="bg-white rounded-xl border border-indigo-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-indigo-600">Incoming</p>
    <p class="text-2xl sm:text-3xl font-bold text-indigo-700 mt-2"><%= parseInt(s.transferring_count || 0) %></p>
    <p class="text-xs text-gray-400 mt-1">Confirm received</p>
  </div>
  <div class="bg-white rounded-xl border border-purple-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-purple-600">To Distribute</p>
    <p class="text-2xl sm:text-3xl font-bold text-purple-700 mt-2"><%= parseInt(s.received_count || 0) %></p>
    <p class="text-xs text-gray-400 mt-1">Send to studios</p>
  </div>
  <div class="bg-white rounded-xl border border-emerald-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-emerald-600">Your Earnings</p>
    <p class="text-lg sm:text-2xl font-bold text-emerald-700 mt-2">MYR <%= idEarnings.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></p>
    <p class="text-xs text-emerald-500 font-medium mt-1">~IDR <%= Math.round(idEarnings * rate).toLocaleString('id-ID') %></p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-gray-500">Distributed</p>
    <p class="text-2xl sm:text-3xl font-bold text-emerald-600 mt-2"><%= parseInt(s.distributed_count || 0) + parseInt(s.completed_count || 0) %></p>
    <p class="text-xs text-gray-400 mt-1">Sent to studios</p>
  </div>
</div>

<!-- ═══ STUDIO ═══ -->
<% } else if (user.role === 'studio') { %>
<div class="grid grid-cols-2 gap-3 sm:gap-4 mt-6">
  <div class="bg-white rounded-xl border border-gray-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-gray-500">My Invoices</p>
    <p class="text-2xl sm:text-3xl font-bold text-gray-800 mt-2"><%= parseInt(s.total_entries) %></p>
    <p class="text-xs text-gray-400 mt-1">Total uploaded</p>
  </div>
  <div class="bg-white rounded-xl border border-emerald-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-emerald-600">Estimated Net</p>
    <p class="text-lg sm:text-2xl font-bold text-emerald-700 mt-2">~MYR <%= studioNet.toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></p>
    <p class="text-xs text-emerald-500 font-medium mt-1">~IDR <%= Math.round(studioNet * rate).toLocaleString('id-ID') %></p>
  </div>
  <div class="col-span-2 bg-white rounded-xl border border-orange-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-orange-600">To Confirm</p>
    <p class="text-2xl sm:text-3xl font-bold text-orange-700 mt-2"><%= parseInt(s.distributed_count || 0) %></p>
    <p class="text-xs text-gray-400 mt-1">Confirm money received</p>
  </div>
</div>
<% } %>

<!-- Exchange Rate + Accounts -->
<div class="grid grid-cols-2 gap-3 sm:gap-4 mt-4">
  <div class="bg-white rounded-xl border border-gray-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-gray-500">Exchange Rate</p>
    <p class="text-base sm:text-xl font-bold text-gray-800 mt-2">1 MYR = <%= rate.toLocaleString() %> IDR</p>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-4 sm:p-5 shadow-sm">
    <p class="text-xs font-medium text-gray-500">Active Accounts</p>
    <p class="text-xl font-bold text-gray-800 mt-2"><%= affiliates.filter(a => a.is_active).length %></p>
    <a href="/shopee/affiliates" class="text-xs text-indigo-600 hover:underline">View →</a>
  </div>
</div>

<!-- Recent Payouts -->
<div class="mt-6 sm:mt-8">
  <div class="flex items-center justify-between mb-3 sm:mb-4">
    <h2 class="text-base sm:text-lg font-semibold text-gray-800">Recent Payouts</h2>
    <a href="/shopee/payouts" class="text-xs sm:text-sm text-indigo-600 hover:text-indigo-500 font-medium">View all →</a>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-4 py-3 font-semibold text-gray-600">Account Holder</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600 hidden sm:table-cell">Date</th>
            <th class="text-right px-4 py-3 font-semibold text-gray-600">MYR</th>
            <th class="text-center px-4 py-3 font-semibold text-gray-600">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% if (recentPayouts.length === 0) { %>
            <tr><td colspan="4" class="px-4 py-6 text-center text-gray-400">No payouts yet</td></tr>
          <% } %>
          <% recentPayouts.forEach(e => { %>
            <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location='/shopee/payouts/<%= e.id %>'">
              <td class="px-4 py-3">
                <p class="font-medium text-gray-800 text-sm truncate max-w-[140px] sm:max-w-none"><%= e.affiliate_name || e.extracted_name %></p>
                <p class="text-xs text-gray-400 sm:hidden"><%= e.invoice_date ? new Date(e.invoice_date).toLocaleDateString('en-GB') : '' %></p>
              </td>
              <td class="px-4 py-3 text-gray-600 whitespace-nowrap hidden sm:table-cell"><%= e.invoice_date ? new Date(e.invoice_date).toLocaleDateString('en-GB') : '-' %></td>
              <td class="px-4 py-3 text-right">
                <span class="font-semibold text-gray-800"><%= parseFloat(e.payout_amount).toLocaleString('en-MY',{minimumFractionDigits:2,maximumFractionDigits:2}) %></span>
                <span class="text-xs text-gray-300 block">~IDR <%= Math.round(parseFloat(e.payout_amount) * rate).toLocaleString('id-ID') %></span>
              </td>
              <td class="px-4 py-3 text-center">
                <span class="px-2 py-0.5 rounded-full text-[10px] sm:text-xs font-medium <%= colors[e.payment_status] || '' %>"><%= e.payment_status %></span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
