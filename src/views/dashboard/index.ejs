<%
  const fmtMYR = n => parseFloat(n||0).toLocaleString('en-MY', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  // Floor IDR to nearest 100 — Indonesian banks don't transfer fractional rupiahs.
  const fmtIDR = n => (Math.floor(Math.max(0, parseFloat(n||0)) / 100) * 100).toLocaleString('id-ID');

  const s = payoutStats;
  const totalMYR = parseFloat(s.total_myr || 0);
  // All deductions are computed as a slice of GROSS (matches manual reconciliation sheet).
  const genPct = deductions.general;
  const myPct  = deductions.myAdmin;
  const hqPct  = deductions.myHQ || 0;
  const idPct  = deductions.idAdmin;
  const SHOPEE_PCT = 1 + 0.01 * 8; // 1% + 0.08% (SST = 8% of Shopee fee)
  const afterMyAdmin = totalMYR * (100 - SHOPEE_PCT - genPct - myPct - hqPct) / 100;
  const idEarnings   = totalMYR * idPct / 100;
  const studioNet    = totalMYR * (100 - SHOPEE_PCT - genPct - myPct - hqPct - idPct) / 100;
  const myEarnings   = totalMYR * myPct / 100;

  const stageColors = {
    processing:   { bg:'bg-slate-50',   text:'text-slate-600',   ring:'ring-slate-200/70' },
    collected:    { bg:'bg-amber-50',   text:'text-amber-700',   ring:'ring-amber-200/70' },
    transferring: { bg:'bg-indigo-50',  text:'text-indigo-700',  ring:'ring-indigo-200/70' },
    received:     { bg:'bg-purple-50',  text:'text-purple-700',  ring:'ring-purple-200/70' },
    distributed:  { bg:'bg-orange-50',  text:'text-orange-700',  ring:'ring-orange-200/70' },
    completed:    { bg:'bg-emerald-50', text:'text-emerald-700', ring:'ring-emerald-200/70' },
  };
%>

<!-- Header -->
<div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-5">
  <div>
    <h1 class="text-xl sm:text-2xl font-bold text-slate-900 tracking-tight">Dashboard</h1>
    <p class="text-slate-500 text-sm mt-1">Welcome back, <%= user.name %>.</p>
  </div>
  <div class="flex items-center gap-2 text-xs">
    <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-indigo-50 text-indigo-700 rounded-full font-medium ring-1 ring-indigo-100 tabular-nums">
      FX 1 MYR ≈ <%= rate.toLocaleString() %> IDR
      <% if (rateMeta && rateMeta.updated_at) { %><span class="text-indigo-400">· <%= relativeTime(rateMeta.updated_at) %></span><% } %>
    </span>
  </div>
</div>

<!-- ═══════════ SUPERADMIN ═══════════ -->
<% if (user.role === 'superadmin') { %>
  <!-- Hero KPI strip -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-5">
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4 sm:p-5">
      <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider">Total Invoices</p>
      <p class="text-2xl sm:text-3xl font-bold text-slate-900 mt-1.5 tabular-nums"><%= parseInt(s.total_entries) %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4 sm:p-5">
      <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider">Total Volume</p>
      <p class="text-lg sm:text-2xl font-bold text-slate-900 mt-1.5 tabular-nums">MYR <%= fmtMYR(totalMYR) %></p>
      <p class="text-[11px] text-slate-400 tabular-nums mt-1">~IDR <%= fmtIDR(totalMYR * rate) %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4 sm:p-5">
      <p class="text-[10px] font-semibold text-emerald-600 uppercase tracking-wider">Studio Net</p>
      <p class="text-lg sm:text-2xl font-bold text-emerald-700 mt-1.5 tabular-nums">MYR <%= fmtMYR(studioNet) %></p>
      <p class="text-[11px] text-emerald-500/70 tabular-nums mt-1">~IDR <%= fmtIDR(studioNet * rate) %></p>
    </div>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4 sm:p-5">
      <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider">Active Accounts</p>
      <p class="text-2xl sm:text-3xl font-bold text-slate-900 mt-1.5 tabular-nums"><%= affiliates.filter(a => a.is_active).length %></p>
      <a href="/shopee/affiliates" class="text-[10px] text-indigo-600 hover:text-indigo-700 font-semibold tracking-wide uppercase mt-1 inline-block">View all →</a>
    </div>
  </div>

  <!-- Pipeline progress strip -->
  <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4 mb-5">
    <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-3">Pipeline</p>
    <div class="grid grid-cols-3 sm:grid-cols-6 gap-2">
      <% ['processing','collected','transferring','received','distributed','completed'].forEach(st => { const c = stageColors[st]; %>
        <div class="<%= c.bg %> rounded-lg ring-1 <%= c.ring %> p-2.5 text-center">
          <p class="text-[9px] font-semibold uppercase tracking-wider <%= c.text %>"><%= st %></p>
          <p class="text-lg sm:text-xl font-bold mt-0.5 tabular-nums <%= c.text %>"><%= parseInt(s[st+'_count'] || 0) %></p>
        </div>
      <% }) %>
    </div>
  </div>

<!-- ═══════════ MALAYSIA ADMIN ═══════════ -->
<% } else if (user.role === 'malaysia_admin' && myAdminData) { %>
  <%
    const ma = myAdminData;
    const STAGE_COLORS = { processing:'slate', collected:'amber', transferring:'indigo', received:'purple', distributed:'orange', completed:'emerald' };
    const heroBg = ma.heroAction.kind === 'collect'  ? 'from-amber-50 to-white ring-amber-200'
                  : ma.heroAction.kind === 'transfer' ? 'from-indigo-50 to-white ring-indigo-200'
                  : 'from-emerald-50 to-white ring-emerald-200';
    const heroAccent = ma.heroAction.kind === 'collect'  ? { txt:'text-amber-700',  btn:'bg-amber-600  hover:bg-amber-700' }
                      : ma.heroAction.kind === 'transfer' ? { txt:'text-indigo-700', btn:'bg-indigo-600 hover:bg-indigo-700' }
                      : { txt:'text-emerald-700', btn:'bg-emerald-600 hover:bg-emerald-700' };
  %>

  <!-- 1. HERO ACTION CARD (compact) -->
  <% if (ma.heroAction.href) { %>
    <div class="bg-gradient-to-br <%= heroBg %> ring-1 rounded-2xl shadow-sm p-4 sm:p-5 mb-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div class="min-w-0 flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-white/60 ring-1 ring-white/80 flex items-center justify-center shrink-0 <%= heroAccent.txt %>">
          <% if (ma.heroAction.kind === 'collect') { %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z"/></svg>
          <% } else { %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          <% } %>
        </div>
        <div class="min-w-0">
          <p class="text-[10px] font-semibold uppercase tracking-wider <%= heroAccent.txt %>">Today's Action</p>
          <p class="text-[15px] sm:text-base font-bold text-slate-900 tracking-tight"><%= ma.heroAction.title %></p>
          <p class="text-[11px] text-slate-500 mt-0.5 tabular-nums">
            <%= ma.heroAction.count %> entries
            <% if (ma.heroAction.banks) { %> · <%= ma.heroAction.banks %> bank<%= ma.heroAction.banks === 1 ? '' : 's' %><% } %>
          </p>
        </div>
      </div>
      <a href="<%= ma.heroAction.href %>" class="inline-flex items-center justify-center gap-2 px-4 py-2 <%= heroAccent.btn %> text-white text-[11px] font-semibold tracking-wide uppercase rounded-lg shadow-sm whitespace-nowrap shrink-0">
        <%= ma.heroAction.cta %>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  <% } %>

  <!-- 2. PRIMARY KPI ROW — what to do, what to send, what you'll earn -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-3 mb-3">
    <!-- To Collect -->
    <div class="bg-white rounded-2xl shadow-sm ring-1 <%= ma.flow.toCollectMyr > 0 ? 'ring-blue-200' : 'ring-slate-200/70' %> p-5">
      <div class="flex items-center justify-between mb-2">
        <p class="text-[10px] font-semibold text-blue-600 uppercase tracking-wider">To Collect</p>
        <span class="text-[10px] text-slate-400 tabular-nums"><%= ma.flow.toCollectCount %> invoices</span>
      </div>
      <p class="text-2xl sm:text-3xl font-bold text-slate-900 tabular-nums">MYR <%= fmtMYR(ma.flow.toCollectMyr) %></p>
      <p class="text-[11px] text-slate-500 tabular-nums mt-1">~IDR <%= fmtIDR(ma.flow.toCollectMyr * rate) %> · <%= ma.flow.pendingBanks %> bank<%= ma.flow.pendingBanks === 1 ? '' : 's' %></p>
    </div>

    <!-- Send to Indonesia -->
    <div class="bg-white rounded-2xl shadow-sm ring-1 <%= ma.flow.atHandMyr > 0 ? 'ring-indigo-300' : 'ring-slate-200/70' %> p-5 relative">
      <div class="flex items-center justify-between mb-2">
        <p class="text-[10px] font-semibold text-indigo-600 uppercase tracking-wider">Send to Indonesia</p>
        <% if (ma.flow.atHandMyr > 0) { %>
          <a href="/shopee/payouts" class="text-[10px] font-semibold text-indigo-600 hover:text-indigo-800 tracking-wide uppercase">Transfer →</a>
        <% } else { %>
          <span class="text-[10px] text-slate-400 tabular-nums"><%= ma.flow.atHandCount %> ready</span>
        <% } %>
      </div>
      <p class="text-2xl sm:text-3xl font-bold text-indigo-700 tabular-nums">MYR <%= fmtMYR(ma.flow.atHandMyr) %></p>
      <p class="text-[11px] text-slate-500 tabular-nums mt-1">~IDR <%= fmtIDR(ma.flow.atHandMyr * rate) %> · <%= ma.flow.atHandCount %> entries collected, ready to forward</p>
    </div>

    <!-- Your Commission This Month -->
    <%
      const commThisMonth = ma.earningsThisMonth.admin + ma.earningsThisMonth.hq;
    %>
    <div class="bg-white rounded-2xl shadow-sm ring-1 <%= commThisMonth > 0 ? 'ring-emerald-200' : 'ring-slate-200/70' %> p-5">
      <div class="flex items-center justify-between mb-2">
        <p class="text-[10px] font-semibold text-emerald-600 uppercase tracking-wider">Your Commission</p>
        <span class="text-[10px] text-slate-400 tabular-nums"><%= new Date().toLocaleDateString('en-GB', { month: 'short', year: 'numeric' }) %></span>
      </div>
      <p class="text-2xl sm:text-3xl font-bold text-emerald-700 tabular-nums">MYR <%= fmtMYR(commThisMonth) %></p>
      <p class="text-[11px] text-slate-500 tabular-nums mt-1">
        Admin <span class="font-semibold text-slate-700">MYR <%= fmtMYR(ma.earningsThisMonth.admin) %></span>
        · HQ <span class="font-semibold text-slate-700">MYR <%= fmtMYR(ma.earningsThisMonth.hq) %></span>
      </p>
    </div>
  </div>

  <!-- 3. SECONDARY STRIP -->
  <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 mb-5">
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4">
      <p class="text-[10px] font-semibold text-purple-600 uppercase tracking-wider">In Transit</p>
      <p class="text-base sm:text-lg font-bold text-purple-700 mt-1 tabular-nums">MYR <%= fmtMYR(ma.flow.inTransitMyr) %></p>
      <p class="text-[10.5px] text-slate-400 mt-1 tabular-nums"><%= ma.flow.inTransitCount %> sent · awaiting ID</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4">
      <p class="text-[10px] font-semibold text-emerald-600 uppercase tracking-wider">Settled This Month</p>
      <p class="text-base sm:text-lg font-bold text-emerald-700 mt-1 tabular-nums">MYR <%= fmtMYR(ma.flow.settledMyr) %></p>
      <p class="text-[10.5px] text-slate-400 mt-1 tabular-nums"><%= ma.flow.settledCount %> distributed to studios</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4 col-span-2 lg:col-span-1">
      <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider">All-Time Commission</p>
      <p class="text-base sm:text-lg font-bold text-slate-900 mt-1 tabular-nums">MYR <%= fmtMYR(ma.earningsAllTime.admin + ma.earningsAllTime.hq) %></p>
      <p class="text-[10.5px] text-slate-400 mt-1 tabular-nums">
        Admin <%= fmtMYR(ma.earningsAllTime.admin) %> · HQ <%= fmtMYR(ma.earningsAllTime.hq) %>
      </p>
    </div>
  </div>

  <!-- 3. ACTIVE PERIODS -->
  <% if (ma.activePeriods.length > 0) { %>
    <div class="mb-5">
      <h2 class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider mb-2 px-1">Active Payout Cycles</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
        <% ma.activePeriods.forEach(p => {
             const [yy,mm,dd] = p.invoice_date.split('-');
             const collected = p.statuses.collected + p.statuses.transferring + p.statuses.received + p.statuses.distributed + p.statuses.completed;
             const pct = Math.round((collected / p.total) * 100);
        %>
          <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4">
            <div class="flex items-baseline justify-between mb-2">
              <div>
                <p class="text-[13px] font-semibold text-slate-900 tracking-tight tabular-nums">Payout <%= dd %>/<%= mm %>/<%= yy %></p>
                <% if (p.period_description) { %>
                  <p class="text-[10px] text-slate-500 tabular-nums mt-0.5"><%= p.period_description %></p>
                <% } %>
              </div>
              <span class="text-[10px] text-slate-500 tabular-nums"><%= collected %>/<%= p.total %> collected · <%= pct %>%</span>
            </div>
            <!-- Progress bar -->
            <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden mb-3">
              <div class="h-full bg-emerald-500 transition-all" style="width: <%= pct %>%"></div>
            </div>
            <!-- Status pills strip -->
            <div class="flex flex-wrap gap-1">
              <% Object.entries(p.statuses).forEach(([st, n]) => { if (n === 0) return; const c = STAGE_COLORS[st]; %>
                <span class="px-1.5 py-0.5 rounded-md text-[9.5px] font-semibold tracking-wide bg-<%= c %>-50 text-<%= c %>-700 ring-1 ring-<%= c %>-200/70 tabular-nums"><%= n %> <%= st.toUpperCase() %></span>
              <% }) %>
            </div>
            <p class="text-[10px] text-slate-500 mt-2 tabular-nums">MY+HQ commission this period: <span class="font-semibold text-slate-700">MYR <%= fmtMYR(p.myAdminEarned) %></span></p>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <!-- (Earnings now consolidated into the Top KPI row + Secondary strip above) -->

  <!-- 4. RECENT ACTIVITY -->
  <% if (ma.recentActivity.length > 0) { %>
    <div class="mb-5">
      <h2 class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider mb-2 px-1">Recent Activity</h2>
      <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 overflow-hidden">
        <ul class="divide-y divide-slate-100">
          <% ma.recentActivity.forEach(a => { %>
            <li class="px-4 py-2.5 hover:bg-slate-50/60 cursor-pointer flex items-center justify-between gap-3" onclick="window.location='/shopee/payouts/<%= a.id %>'">
              <div class="flex items-center gap-3 min-w-0">
                <span class="w-1.5 h-1.5 rounded-full bg-<%= a.color %>-500 shrink-0"></span>
                <div class="min-w-0">
                  <p class="text-[13px] text-slate-700 leading-tight"><%= a.label %> · <span class="font-semibold text-slate-900"><%= a.holder %></span></p>
                  <p class="text-[10px] text-slate-400 tabular-nums mt-0.5"><%= a.when ? relativeTime(a.when) : '—' %></p>
                </div>
              </div>
              <span class="font-semibold text-slate-700 text-[13px] tabular-nums shrink-0">MYR <%= fmtMYR(a.amount) %></span>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>
  <% } %>

<!-- ═══════════ INDONESIA ADMIN ═══════════ -->
<% } else if (user.role === 'indonesia_admin' && idAdminData) { %>
  <%
    const ia = idAdminData;
    const heroBgId = ia.heroAction.kind === 'confirm'    ? 'from-purple-50 to-white ring-purple-200'
                    : ia.heroAction.kind === 'distribute' ? 'from-orange-50 to-white ring-orange-200'
                    : 'from-emerald-50 to-white ring-emerald-200';
    const heroAccentId = ia.heroAction.kind === 'confirm'    ? { txt:'text-purple-700', btn:'bg-purple-600 hover:bg-purple-700' }
                        : ia.heroAction.kind === 'distribute' ? { txt:'text-orange-700', btn:'bg-orange-600 hover:bg-orange-700' }
                        : { txt:'text-emerald-700', btn:'bg-emerald-600 hover:bg-emerald-700' };
  %>

  <!-- HERO ACTION CARD -->
  <% if (ia.heroAction.href) { %>
    <div class="bg-gradient-to-br <%= heroBgId %> ring-1 rounded-2xl shadow-sm p-4 sm:p-5 mb-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div class="min-w-0 flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg bg-white/60 ring-1 ring-white/80 flex items-center justify-center shrink-0 <%= heroAccentId.txt %>">
          <% if (ia.heroAction.kind === 'confirm') { %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <% } else { %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          <% } %>
        </div>
        <div class="min-w-0">
          <p class="text-[10px] font-semibold uppercase tracking-wider <%= heroAccentId.txt %>">Today's Action</p>
          <p class="text-[15px] sm:text-base font-bold text-slate-900 tracking-tight"><%= ia.heroAction.title %></p>
          <p class="text-[11px] text-slate-500 mt-0.5 tabular-nums">
            <%= ia.heroAction.count %> entries
            <% if (ia.heroAction.batches) { %> · <%= ia.heroAction.batches %> transfer<%= ia.heroAction.batches === 1 ? '' : 's' %><% } %>
            <% if (ia.heroAction.studios) { %> · <%= ia.heroAction.studios %> studio<%= ia.heroAction.studios === 1 ? '' : 's' %><% } %>
          </p>
        </div>
      </div>
      <a href="<%= ia.heroAction.href %>" class="inline-flex items-center justify-center gap-2 px-4 py-2 <%= heroAccentId.btn %> text-white text-[11px] font-semibold tracking-wide uppercase rounded-lg shadow-sm whitespace-nowrap shrink-0">
        <%= ia.heroAction.cta %>
        <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  <% } %>

  <!-- TOP KPI ROW: Incoming · To Distribute · Your Commission -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-3 mb-5">
    <!-- Incoming -->
    <div class="bg-white rounded-2xl shadow-sm ring-1 <%= ia.flow.incomingMyr > 0 ? 'ring-purple-200' : 'ring-slate-200/70' %> p-5">
      <div class="flex items-center justify-between mb-2">
        <p class="text-[10px] font-semibold text-purple-600 uppercase tracking-wider">Incoming from Malaysia</p>
        <% if (ia.flow.incomingMyr > 0) { %>
          <a href="/shopee/payouts" class="text-[10px] font-semibold text-purple-600 hover:text-purple-800 tracking-wide uppercase">Confirm →</a>
        <% } else { %>
          <span class="text-[10px] text-slate-400 tabular-nums"><%= ia.flow.incomingCount %></span>
        <% } %>
      </div>
      <p class="text-2xl sm:text-3xl font-bold text-purple-700 tabular-nums">MYR <%= fmtMYR(ia.flow.incomingMyr) %></p>
      <p class="text-[11px] text-slate-500 tabular-nums mt-1">
        ~IDR <%= fmtIDR(ia.flow.incomingMyr * rate) %>
        <% if (ia.flow.incomingBatches > 0) { %> · <%= ia.flow.incomingBatches %> batch<%= ia.flow.incomingBatches === 1 ? '' : 'es' %><% } %>
      </p>
    </div>

    <!-- To Distribute -->
    <div class="bg-white rounded-2xl shadow-sm ring-1 <%= ia.flow.toDistributeMyr > 0 ? 'ring-orange-300' : 'ring-slate-200/70' %> p-5">
      <div class="flex items-center justify-between mb-2">
        <p class="text-[10px] font-semibold text-orange-600 uppercase tracking-wider">To Distribute</p>
        <% if (ia.flow.toDistributeMyr > 0) { %>
          <a href="/shopee/payouts/studio-payments" class="text-[10px] font-semibold text-orange-600 hover:text-orange-800 tracking-wide uppercase">Distribute →</a>
        <% } else { %>
          <span class="text-[10px] text-slate-400 tabular-nums"><%= ia.flow.toDistributeCount %></span>
        <% } %>
      </div>
      <p class="text-2xl sm:text-3xl font-bold text-orange-700 tabular-nums">MYR <%= fmtMYR(ia.flow.toDistributeMyr) %></p>
      <p class="text-[11px] text-slate-500 tabular-nums mt-1">
        ~IDR <%= fmtIDR(ia.flow.toDistributeMyr * rate) %>
        <% if (ia.flow.distributeStudios > 0) { %> · <%= ia.flow.distributeStudios %> studio<%= ia.flow.distributeStudios === 1 ? '' : 's' %><% } %>
      </p>
    </div>

    <!-- Your Commission -->
    <div class="bg-white rounded-2xl shadow-sm ring-1 <%= ia.earningsThisMonthMyr > 0 ? 'ring-emerald-200' : 'ring-slate-200/70' %> p-5">
      <div class="flex items-center justify-between mb-2">
        <p class="text-[10px] font-semibold text-emerald-600 uppercase tracking-wider">Your Commission</p>
        <span class="text-[10px] text-slate-400 tabular-nums"><%= new Date().toLocaleDateString('en-GB', { month: 'short', year: 'numeric' }) %></span>
      </div>
      <p class="text-2xl sm:text-3xl font-bold text-emerald-700 tabular-nums">MYR <%= fmtMYR(ia.earningsThisMonthMyr) %></p>
      <p class="text-[11px] text-slate-500 tabular-nums mt-1">
        ~IDR <%= fmtIDR(ia.earningsThisMonthMyr * rate) %>
        · all-time <span class="font-semibold text-slate-700">MYR <%= fmtMYR(ia.earningsAllTimeMyr) %></span>
      </p>
    </div>
  </div>

<!-- ═══════════ STUDIO ═══════════ -->
<% } else if (user.role === 'studio') { %>
  <%
    const toConfirm = parseInt(s.distributed_count) || 0;
  %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-5">
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4 sm:p-5">
      <p class="text-[10px] font-semibold text-slate-500 uppercase tracking-wider">My Invoices</p>
      <p class="text-2xl sm:text-3xl font-bold text-slate-900 mt-1.5 tabular-nums"><%= parseInt(s.total_entries) %></p>
      <p class="text-[11px] text-slate-400 mt-1">Total uploaded</p>
    </div>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-4 sm:p-5 <%= toConfirm > 0 ? 'ring-2 ring-orange-400/60' : '' %>">
      <p class="text-[10px] font-semibold uppercase tracking-wider <%= toConfirm > 0 ? 'text-orange-600' : 'text-slate-500' %>">To Confirm</p>
      <p class="text-2xl sm:text-3xl font-bold mt-1.5 tabular-nums <%= toConfirm > 0 ? 'text-orange-700' : 'text-slate-900' %>"><%= toConfirm %></p>
      <p class="text-[11px] mt-1 <%= toConfirm > 0 ? 'text-orange-600' : 'text-slate-400' %>">
        <% if (toConfirm > 0) { %>
          <a href="/shopee/payouts" class="hover:underline">Confirm money received →</a>
        <% } else { %>
          Nothing pending
        <% } %>
      </p>
    </div>
  </div>
<% } %>

<!-- Recent Payouts -->
<div class="mb-5">
  <div class="flex items-baseline justify-between mb-2 px-1">
    <h2 class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider">Recent Payouts</h2>
    <a href="/shopee/payouts" class="text-[10px] text-indigo-600 hover:text-indigo-700 font-semibold tracking-wide uppercase">View all →</a>
  </div>
  <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-[13px]">
        <thead class="bg-slate-50/80 border-b border-slate-200/70 text-slate-500 text-[10px] uppercase tracking-wider">
          <tr>
            <th class="text-left  px-3 py-2.5 font-semibold">Account Holder</th>
            <th class="text-left  px-3 py-2.5 font-semibold hidden sm:table-cell">Date</th>
            <th class="text-right px-3 py-2.5 font-semibold">Amount</th>
            <th class="text-center px-3 py-2.5 font-semibold">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% if (recentPayouts.length === 0) { %>
            <tr><td colspan="4" class="px-4 py-8 text-center text-slate-400 text-sm">No payouts yet</td></tr>
          <% } %>
          <% recentPayouts.forEach(e => {
               const c = stageColors[e.payment_status] || stageColors.processing;
               const dt = e.invoice_date ? new Date(e.invoice_date) : null;
               const dateStr = dt ? `${String(dt.getDate()).padStart(2,'0')}/${String(dt.getMonth()+1).padStart(2,'0')}/${dt.getFullYear()}` : '—';
          %>
            <tr class="hover:bg-slate-50/60 transition-colors cursor-pointer" onclick="window.location='/shopee/payouts/<%= e.id %>'">
              <td class="px-3 py-2.5">
                <p class="font-semibold text-slate-900 text-sm leading-tight truncate max-w-[160px] sm:max-w-none"><%= e.affiliate_name || e.extracted_name %></p>
                <p class="text-[10px] text-slate-400 sm:hidden tabular-nums mt-0.5"><%= dateStr %></p>
              </td>
              <td class="px-3 py-2.5 text-slate-500 tabular-nums whitespace-nowrap hidden sm:table-cell"><%= dateStr %></td>
              <td class="px-3 py-2.5 text-right">
                <span class="font-semibold text-slate-900 tabular-nums">MYR <%= fmtMYR(e.payout_amount) %></span>
                <span class="block text-[10px] text-slate-400 tabular-nums mt-0.5">~IDR <%= fmtIDR(parseFloat(e.payout_amount) * rate) %></span>
              </td>
              <td class="px-3 py-2.5 text-center">
                <span class="px-1.5 py-0.5 rounded-md text-[9.5px] font-semibold tracking-wide <%= c.bg %> <%= c.text %> ring-1 <%= c.ring %>"><%= e.payment_status.toUpperCase() %></span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Top Affiliates by Volume — not shown to studio role (they only see their own studio) -->
<% if (user.role !== 'studio' && affiliateSummary && affiliateSummary.length > 0) { %>
  <div>
    <div class="flex items-baseline justify-between mb-2 px-1">
      <h2 class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider">Top Affiliates by Volume</h2>
      <a href="/shopee/affiliates" class="text-[10px] text-indigo-600 hover:text-indigo-700 font-semibold tracking-wide uppercase">All accounts →</a>
    </div>
    <div class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-[13px]">
          <thead class="bg-slate-50/80 border-b border-slate-200/70 text-slate-500 text-[10px] uppercase tracking-wider">
            <tr>
              <th class="text-left  px-3 py-2.5 font-semibold">Name</th>
              <th class="text-right px-3 py-2.5 font-semibold">Entries</th>
              <th class="text-center px-3 py-2.5 font-semibold hidden sm:table-cell">Pipeline</th>
              <th class="text-right px-3 py-2.5 font-semibold">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% affiliateSummary.forEach(row => {
                const myr = parseFloat(row.total_myr || 0);
                const proc = parseInt(row.processing_count || 0);
                const done = parseInt(row.completed_count || 0);
            %>
              <tr class="hover:bg-slate-50/60 transition-colors">
                <td class="px-3 py-2.5">
                  <p class="font-semibold text-slate-900 text-sm leading-tight truncate max-w-[180px] sm:max-w-none"><%= row.name || '—' %></p>
                  <p class="text-[10px] text-slate-400 sm:hidden mt-0.5">
                    <% if (proc > 0) { %><span class="text-amber-600 font-medium"><%= proc %> proc</span><% } %>
                    <% if (proc > 0 && done > 0) { %> · <% } %>
                    <% if (done > 0) { %><span class="text-emerald-600 font-medium"><%= done %> done</span><% } %>
                  </p>
                </td>
                <td class="px-3 py-2.5 text-right text-slate-700 tabular-nums"><%= parseInt(row.entry_count) %></td>
                <td class="px-3 py-2.5 text-center hidden sm:table-cell">
                  <% if (proc > 0) { %>
                    <span class="px-1.5 py-0.5 rounded-md text-[9.5px] font-semibold tracking-wide bg-amber-50 text-amber-700 ring-1 ring-amber-200/70"><%= proc %> PROC</span>
                  <% } %>
                  <% if (done > 0) { %>
                    <span class="px-1.5 py-0.5 rounded-md text-[9.5px] font-semibold tracking-wide bg-emerald-50 text-emerald-700 ring-1 ring-emerald-200/70"><%= done %> DONE</span>
                  <% } %>
                  <% if (proc === 0 && done === 0) { %>
                    <span class="text-slate-300 text-xs">—</span>
                  <% } %>
                </td>
                <td class="px-3 py-2.5 text-right">
                  <span class="font-semibold text-slate-900 tabular-nums">MYR <%= fmtMYR(myr) %></span>
                  <span class="block text-[10px] text-slate-400 tabular-nums mt-0.5">~IDR <%= fmtIDR(myr * rate) %></span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% } %>
