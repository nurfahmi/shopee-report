<div class="max-w-xl">
  <div class="flex items-center gap-3 mb-5">
    <a href="/studios" class="text-slate-400 hover:text-slate-700 shrink-0">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    </a>
    <h1 class="text-xl sm:text-2xl font-bold text-slate-900 tracking-tight"><%= editing ? 'Edit Studio' : 'Create Studio' %></h1>
  </div>

  <form method="POST" action="<%= editing ? `/studios/${data.id}/edit` : '/studios/create' %>" class="bg-white rounded-xl shadow-sm ring-1 ring-slate-200/70 p-5 sm:p-6 space-y-5">
    <div>
      <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Studio Name</label>
      <input type="text" name="name" value="<%= data.name || '' %>" required autofocus
        class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 focus:border-slate-900 outline-none">
    </div>

    <!-- Bank details — used by ID admin when transferring payouts to the studio. -->
    <div class="border-t border-slate-100 pt-5">
      <p class="text-[11px] font-semibold text-slate-500 uppercase tracking-wider mb-3">Bank Details</p>
      <div class="space-y-3">
        <div>
          <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Bank Name</label>
          <input type="text" name="bank_name" value="<%= data.bank_name || '' %>"
            placeholder="e.g. BCA, Mandiri, BNI"
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 focus:border-slate-900 outline-none">
        </div>
        <div>
          <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Account Holder Name</label>
          <input type="text" name="bank_account_holder" value="<%= data.bank_account_holder || '' %>"
            placeholder="As shown on the bank account"
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:ring-2 focus:ring-slate-900 focus:border-slate-900 outline-none">
        </div>
        <div>
          <label class="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Account Number</label>
          <input type="text" name="bank_account_number" value="<%= data.bank_account_number || '' %>"
            placeholder="Bank account number"
            class="w-full px-3 py-2 border border-slate-300 rounded-lg text-sm font-mono tabular-nums focus:ring-2 focus:ring-slate-900 focus:border-slate-900 outline-none">
        </div>
      </div>
      <p class="text-[10.5px] text-slate-400 mt-2">These details appear on the studio payments page so the ID admin can transfer without leaving the app.</p>
    </div>

    <div class="flex gap-2 pt-1">
      <button type="submit" class="px-4 py-2 bg-slate-900 hover:bg-slate-800 text-white text-[11px] font-semibold tracking-wide uppercase rounded-lg shadow-sm">
        <%= editing ? 'Update' : 'Create' %> Studio
      </button>
      <a href="/studios" class="px-4 py-2 text-slate-500 hover:text-slate-700 text-[11px] font-semibold tracking-wide uppercase">Cancel</a>
    </div>
  </form>
</div>
